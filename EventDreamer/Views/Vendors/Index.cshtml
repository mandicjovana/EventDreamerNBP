@model IEnumerable<EventDreamer.Models.Vendor>
@{
    Layout = null;
    var dogadjaji = ViewBag.MojiDogadjaji as List<EventDreamer.Models.Event>;

    // trenurne vrijednosti
    int trenutnaKategorijaId = ViewBag.TrenutnaKategorija ?? 0;
    decimal? trenutnaMaxCijena = ViewBag.TrenutnaCijena;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pretraga vendora - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        /* pozadina */
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            z-index: 1;
        }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        /* svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .title-icon {
            vertical-align: text-bottom;
            margin-right: 8px;
            width: 28px;
            height: 28px;
        }

        .btn-icon {
            margin-right: 6px;
            vertical-align: middle;
            width: 16px;
            height: 16px;
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-nav-container {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: #111;
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: #111;
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* za dugmice boje sa loga */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        /* pretraga i filteri */
        .search-filter-box {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(15px);
            padding: 25px;
            border-radius: 20px;
            margin-bottom: 35px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 8px 25px rgba(0,0,0,0.03);
        }

        .filter-form {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .form-group-custom {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
            min-width: 200px;
        }

        .form-group-custom label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            color: #444;
            letter-spacing: 0.5px;
        }

        .form-control-custom {
            padding: 12px 15px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            background: #fff;
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 14px;
            outline: none;
            transition: 0.3s;
        }

        .form-control-custom:focus {
            border-color: var(--logo-green);
        }

        .btn-search-submit {
            padding: 13px 30px;
            background: #111;
            color: #fff;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
            font-size: 13px;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-search-submit:hover {
            background: var(--logo-green);
            color: #111;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* kartice vendora */
        .vendor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
        }

        .vendor-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

        .vendor-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        .vendor-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, var(--logo-pink), var(--logo-green));
        }

        .img-placeholder {
            width: 100%;
            height: 200px;
            border-radius: 15px;
            margin-bottom: 20px;
            background-size: cover;
            background-position: center;
            background-color: #ddd;
        }

        .v-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 10px 0;
            color: #111;
        }

        .v-badge {
            display: inline-block;
            padding: 6px 14px;
            background: var(--logo-pink);
            color: #111;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 15px;
            align-self: flex-start;
        }

        .v-info {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #444;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-zakazi {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 14px;
            background: var(--logo-green);
            color: #111;
            border: none;
            border-radius: 12px;
            font-weight: 800;
            cursor: pointer;
            margin-top: auto;
            transition: 0.3s;
            text-transform: uppercase;
            text-align: center;
            font-size: 14px;
        }

        .btn-zakazi:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
        }

        /* za zakazivanje */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #fff;
            width: 95%;
            max-width: 550px;
            max-height: 90vh;
            overflow-y: auto;
            border-radius: 20px;
            padding: 35px;
            position: relative;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 25px;
            font-size: 28px;
            cursor: pointer;
            border: none;
            background: none;
            font-weight: bold;
            color: #333;
            transition: 0.2s;
        }

        .close-modal:hover {
            color: #e63946;
        }

        .modal-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 5px;
            margin-top: 0;
        }

        .modal-subtitle {
            color: #666;
            font-size: 15px;
            margin-bottom: 25px;
            font-weight: 600;
        }

        .modal-box {
            background: rgba(246, 222, 234, 0.25);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(246, 222, 234, 0.8);
        }

        .modal-label {
            font-size: 13px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            text-transform: uppercase;
            color: #444;
        }

        .modal-input, .modal-select {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            background: #fff;
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            margin-bottom: 15px;
            box-sizing: border-box;
            outline: none;
            cursor: pointer;
        }

        .modal-input:focus, .modal-select:focus {
            border-color: var(--logo-green);
        }

        /* dinamicki kalendar */
        .custom-calendar {
            background: #fafafa;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 25px;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .cal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 800;
            margin-bottom: 20px;
            font-size: 16px;
        }

        .cal-header button {
            background: #e2e2e2;
            border: none;
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Montserrat', sans-serif;
            font-size: 12px;
            text-transform: uppercase;
        }

        .cal-header button:hover {
            background: #d0d0d0;
        }

        .cal-header-title {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .cal-weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            font-size: 12px;
            font-weight: 800;
            color: #888;
            margin-bottom: 15px;
        }

        .cal-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 8px;
        }

        .cal-day {
            padding: 10px 0;
            text-align: center;
            border-radius: 10px;
            border: 1px solid #eee;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .cal-day.green {
            border-color: rgba(188, 197, 170, 0.5);
            background: rgba(188, 197, 170, 0.15);
            color: #222;
        }

        .cal-day.red {
            border-color: #fce8e6;
            background: #fdf2f1;
            color: #ccc;
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            margin-top: 5px;
        }

        .dot.green {
            background: #5a9e5a;
        }

        .dot.red {
            background: #e63946;
        }

        .modal-event-card {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            transition: 0.2s;
        }

        .modal-event-card:hover {
            border-color: var(--logo-green);
            background: #fcfcfc;
        }

        .modal-event-card input[type="radio"] {
            transform: scale(1.3);
            cursor: pointer;
        }

        .btn-submit-modal {
            width: 100%;
            background: var(--logo-green);
            color: #111;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-weight: 800;
            font-size: 15px;
            cursor: pointer;
            margin-top: 15px;
            transition: 0.3s;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-submit-modal:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .btn-submit-modal:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
            color: #666;
        }

        /* responsive dizajn */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-nav-container {
                display: none;
                width: 100%;
                margin-top: 20px;
                flex-direction: column;
            }

            .sidebar-nav-container.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
                transform: none !important;
            }

            .sidebar-menu a:hover:not(.active) {
                transform: none !important;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .vendor-grid {
                grid-template-columns: 1fr;
            }

            .filter-form {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                    </svg>
                    EventDreamer
                </h2>
            </div>

            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
                EventDreamer
            </div>

            <div class="sidebar-nav-container" id="navContainer">
                <ul class="sidebar-menu">
                    <li>
                        <a href="@Url.Action("Index", "Dashboard")">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                            Kontrolna tabla
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("MojiDogadjaji", "Dashboard")">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                            Moji događaji
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Tasks")">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                            Lista zadataka
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Guests")">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            Lista gostiju
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Budget")">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                            Budžet i troškovi
                        </a>
                    </li>
                    <li>
                        <a href="#" class="active">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                            Pronađi vendore
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                    </li>
                </ul>
                <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                    Odjavi se
                </a>
            </div>
        </div>

        <div class="main-content">
            @if (TempData["Poruka"] != null)
            {
                <div style="display:flex; align-items:center; gap:10px; background: #e6f4ea; color: #137333; padding: 15px 20px; border-radius: 12px; font-weight: 700; margin-bottom: 25px; border: 1px solid #c3e6cb; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    @TempData["Poruka"]
                </div>
            }

            <div class="search-filter-box">
                @using (Html.BeginForm("Index", "Vendors", FormMethod.Get, new { @class = "filter-form" }))
                {
                    <div class="form-group-custom">
                        <label for="kId">Kategorija usluge</label>
                        <select name="kId" id="kId" class="form-control-custom">
                            <option value="0" @(trenutnaKategorijaId == 0 ? "selected" : "")>Sve kategorije</option>
                            <option value="1" @(trenutnaKategorijaId == 1 ? "selected" : "")>Sale i restorani</option>
                            <option value="2" @(trenutnaKategorijaId == 2 ? "selected" : "")>Fotografi</option>
                            <option value="3" @(trenutnaKategorijaId == 3 ? "selected" : "")>Muzika / bend</option>
                            <option value="4" @(trenutnaKategorijaId == 4 ? "selected" : "")>Dekoracija</option>
                            <option value="5" @(trenutnaKategorijaId == 5 ? "selected" : "")>Torte i slatkiši</option>
                        </select>
                    </div>

                    <div class="form-group-custom">
                        <label for="maxCijena">Maksimalni budžet (€)</label>
                        <input type="number" name="maxCijena" id="maxCijena"
                               value="@(trenutnaMaxCijena.HasValue ? trenutnaMaxCijena.Value.ToString("0.00") : "")"
                               class="form-control-custom" placeholder="Npr. 1500" min="0" step="1" />
                    </div>

                    <button type="submit" class="btn-search-submit">
                        <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        Primijeni filtere
                    </button>
                }
            </div>

            <div class="vendor-grid">
                @if (Model != null && Model.Any())
                {
                    foreach (var v in Model)
                    {
                        <div class="vendor-card">
                            <div class="img-placeholder" style="background-image: url('@v.ImagePath');"></div>
                            <h3 class="v-title">@v.Name</h3>
                            <div class="v-badge">@(v.VendorCategory != null ? v.VendorCategory.CategoryName : "Bez kategorije")</div>
                            <div class="v-info">
                                <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                <strong>Kontakt:</strong> @v.Contact
                            </div>
                            <div class="v-info">
                                <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                                <strong>Cijena:</strong> @v.BasePrice €
                                @if (v.CategoryID == 1)
                                {
                                    <span style="color: #666; font-size: 13px; align-self: flex-end; margin-left: 5px;">/ po osobi</span>
                                }
                            </div>

                            <button type="button" class="btn-zakazi" onclick="otvoriModal(@v.Id, '@v.Name.Replace("'", "\\'")', '@v.BasePrice', @v.CategoryID)">
                                <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                Zakaži termin
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1 / -1; text-align: center; font-weight: 600; padding: 40px; background: rgba(255,255,255,0.5); border-radius: 20px; display:flex; flex-direction:column; align-items:center; gap:10px;">
                        <svg class="svg-icon icon-lg" viewBox="0 0 24 24" style="color: #888;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        Trenutno nema vendora koji ispunjavaju zadate kriterijume pretrage.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="bookingModal">
        <div class="modal-content">
            <button class="close-modal" onclick="zatvoriModal()">×</button>
            <h2 class="modal-title" id="modalVendorName">Zakaži</h2>
            <div class="modal-subtitle" id="modalVendorPrice">Osnovna cijena: 0.00 €</div>

            <form action="@Url.Action("PosaljiUpit", "Vendors")" method="post" id="bookingForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="vendorId" id="hiddenVendorId" />

                <div class="modal-box" id="paketContainer" style="display: none;">
                    <label class="modal-label">Odaberite paket usluga:</label>
                    <select name="odabraniPaket" id="paketSelect" class="modal-select" onchange="racunajCijenu()">
                        <option value="premium">Svadbeni paket (Premium)</option>
                        <option value="standard">Rođendanski paket (Standard)</option>
                        <option value="poslovni">Poslovni paket</option>
                    </select>

                    <label class="modal-label">Unesite broj gostiju:</label>
                    <input type="number" name="brojGostiju" id="brojGostijuInput" class="modal-input" placeholder="Npr. 150" oninput="racunajCijenu()" />

                    <div id="ukupnaCijenaPrikaz" style="margin-top: 10px; color: #111; font-size: 15px; font-weight: 800;"></div>
                </div>

                <div class="custom-calendar">
                    <div class="cal-header">
                        <button type="button" onclick="promijeniMjesec(-1)">&lt; Nazad</button>
                        <span id="mjGodinaPrikaz" class="cal-header-title"></span>
                        <button type="button" onclick="promijeniMjesec(1)">Naprijed &gt;</button>
                    </div>
                    <div class="cal-weekdays">
                        <span>PON</span><span>UTO</span><span>SRI</span><span>ČET</span><span>PET</span><span>SUB</span><span>NED</span>
                    </div>
                    <div class="cal-days" id="calendarDays"></div>
                </div>

                <h3 style="font-size: 15px; text-transform: uppercase; font-weight: 800; margin-bottom: 15px; display:flex; align-items:center; gap:8px;">
                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                    Izaberi svoj događaj:
                </h3>

                @if (dogadjaji != null && dogadjaji.Any())
                {
                    foreach (var dogadjaj in dogadjaji)
                    {
                        string formattedDate = dogadjaj.Date.HasValue ? dogadjaj.Date.Value.ToString("yyyy-MM-dd") : "";
                        string displayDate = dogadjaj.Date.HasValue ? dogadjaj.Date.Value.ToString("dd.MM.yyyy") : "Datum nije određen";

                        <label class="modal-event-card">
                            <div>
                                <strong style="display:block; margin-bottom:5px; font-size: 16px; color: #111;">@dogadjaj.Title</strong>
                                <span style="font-size: 13px; color: #666; font-weight: 600; display:flex; align-items:center; gap:5px;">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                    Datum događaja: @displayDate
                                </span>
                            </div>
                            <input type="radio" name="eventId" value="@dogadjaj.Id" data-datum="@formattedDate" onchange="provjeriDostupnost(this)" required />
                        </label>
                    }
                }
                else
                {
                    <div style="background: #fdf2f1; color: #c5221f; padding: 15px; border-radius: 12px; font-size: 14px; font-weight: 700; margin-bottom: 20px; border: 1px solid #fce8e6; display:flex; align-items:center; gap:8px;">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                        Niste kreirali nijedan događaj! Idite na Moji Događaji da napravite jedan.
                    </div>
                }

                <div id="porukaDostupnosti" style="margin-top: 15px; font-weight: 700; font-size: 14px; text-align: center;"></div>

                <button type="button" class="btn-submit-modal" id="btnPotvrdi" onclick="posaljiRezervaciju()" disabled>
                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    POTVRDI REZERVACIJU
                </button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });

        let currentCategoryId = 0;
        let currentBasePrice = 0;

        const zauzetiDatumiVendora = ['2026-07-01', '2026-07-02', '2026-07-15', '2026-07-22', '2026-08-10', '2026-08-15'];

        function otvoriModal(id, naziv, cijenaStr, categoryId) {
            currentCategoryId = categoryId;
            currentBasePrice = parseFloat(cijenaStr.toString().replace(',', '.'));

            document.getElementById('hiddenVendorId').value = id;
            document.getElementById('modalVendorName').innerText = 'Zakaži: ' + naziv;

            let subtitle = document.getElementById('modalVendorPrice');
            let paketContainer = document.getElementById('paketContainer');
            let brojGostijuInput = document.getElementById('brojGostijuInput');

            if (categoryId === 1) {
                subtitle.innerText = 'Početna cijena menija: ' + currentBasePrice + ' € / osobi';
                paketContainer.style.display = 'block';
                brojGostijuInput.required = true;
                racunajCijenu();
            } else {
                subtitle.innerText = 'Fiksna cijena usluge: ' + currentBasePrice + ' €';
                paketContainer.style.display = 'none';
                brojGostijuInput.required = false;
                document.getElementById('ukupnaCijenaPrikaz').innerHTML = '';
            }

            document.getElementById('bookingForm').reset();
            document.getElementById('btnPotvrdi').disabled = true;
            document.getElementById('porukaDostupnosti').innerHTML = '';

            document.getElementById('bookingModal').style.display = 'flex';
        }

        function zatvoriModal() {
            document.getElementById('bookingModal').style.display = 'none';
        }

        function racunajCijenu() {
            if (currentCategoryId !== 1) return;

            let brojGostiju = document.getElementById('brojGostijuInput').value;
            let paket = document.getElementById('paketSelect').value;
            let prikaz = document.getElementById('ukupnaCijenaPrikaz');

            if (!brojGostiju || brojGostiju <= 0) {
                prikaz.innerHTML = '';
                return;
            }

            let cijenaPoOsobi = currentBasePrice;
            if (paket === 'standard') cijenaPoOsobi = Math.max(15, currentBasePrice - 10);
            else if (paket === 'poslovni') cijenaPoOsobi = Math.max(10, currentBasePrice - 15);

            let ukupno = cijenaPoOsobi * brojGostiju;
            prikaz.innerHTML = 'Ukupna procijenjena cijena: <span style="color:var(--logo-green); font-size:18px;">' + ukupno.toFixed(2) + ' €</span>';
        }

        const naziviMjeseci = ['Januar', 'Februar', 'Mart', 'April', 'Maj', 'Jun', 'Jul', 'Avgust', 'Septembar', 'Oktobar', 'Novembar', 'Decembar'];

        let prikazanaGodina = 2026;
        let prikazaniMjesec = 6;

        function iscrtajKalendar() {
            document.getElementById("mjGodinaPrikaz").innerHTML = '<svg class="svg-icon icon-sm" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> ' + naziviMjeseci[prikazaniMjesec] + ' ' + prikazanaGodina + '.';

            let prviDanUNedelji = new Date(prikazanaGodina, prikazaniMjesec, 1).getDay();
            prviDanUNedelji = prviDanUNedelji === 0 ? 6 : prviDanUNedelji - 1;

            let brojDanaUMjesecu = new Date(prikazanaGodina, prikazaniMjesec + 1, 0).getDate();
            let container = document.getElementById('calendarDays');
            container.innerHTML = '';

            for (let p = 0; p < prviDanUNedelji; p++) {
                container.innerHTML += `<div></div>`;
            }

            for (let i = 1; i <= brojDanaUMjesecu; i++) {
                let mFormat = (prikazaniMjesec + 1) < 10 ? '0' + (prikazaniMjesec + 1) : (prikazaniMjesec + 1);
                let dFormat = i < 10 ? '0' + i : i;
                let datumString = `${prikazanaGodina}-${mFormat}-${dFormat}`;

                let isZauzet = zauzetiDatumiVendora.includes(datumString);
                let klasa = isZauzet ? 'red' : 'green';
                let dot = `<div class="dot ${klasa}"></div>`;

                container.innerHTML += `
                                <div class="cal-day ${klasa}" title="${isZauzet ? 'Zauzeto' : 'Slobodno'}">
                                    ${i}.${dot}
                                </div>`;
            }
        }

        function promijeniMjesec(smjer) {
            prikazaniMjesec += smjer;

            if (prikazaniMjesec > 11) {
                prikazaniMjesec = 0;
                prikazanaGodina++;
            } else if (prikazaniMjesec < 0) {
                prikazaniMjesec = 11;
                prikazanaGodina--;
            }

            iscrtajKalendar();
        }

        iscrtajKalendar();

        function provjeriDostupnost(radioElement) {
            let datumDogadjaja = radioElement.getAttribute('data-datum');
            let btnPotvrdi = document.getElementById('btnPotvrdi');
            let porukaDiv = document.getElementById('porukaDostupnosti');

            if (!datumDogadjaja) {
                porukaDiv.innerHTML = '<div style="display:flex; align-items:center; justify-content:center; gap:6px; color:#e63946;"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg> <span>Vaš događaj nema postavljen datum! Ne možete rezervisati vendora.</span></div>';
                btnPotvrdi.disabled = true;
                return;
            }

            if (zauzetiDatumiVendora.includes(datumDogadjaja)) {
                porukaDiv.innerHTML = '<div style="display:flex; align-items:center; justify-content:center; gap:6px; color:#e63946;"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg> <span>Žao nam je, vendor je ZAUZET na datum Vašeg događaja!</span></div>';
                btnPotvrdi.disabled = true;
            } else {
                porukaDiv.innerHTML = '<div style="display:flex; align-items:center; justify-content:center; gap:6px; color:#137333;"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> <span>Sjajno! Vendor je SLOBODAN na datum Vašeg događaja!</span></div>';
                btnPotvrdi.disabled = false;
            }
        }

        function posaljiRezervaciju() {
            document.getElementById('bookingForm').submit();
        }
    </script>
</body>
</html>