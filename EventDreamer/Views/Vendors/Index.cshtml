@model IEnumerable<EventDreamer.Models.Vendor>
@{
    Layout = null;
    var dogadjaji = ViewBag.MojiDogadjaji as List<EventDreamer.Models.Event>;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pretraga vendora - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            background: #f4eade;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.4)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            width: 100%;
        }

        .sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.3);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 22px;
            font-weight: 700;
            color: #000;
            margin-bottom: 40px;
            text-transform: uppercase;
            text-align: center;
        }

        .sidebar-nav-container {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar-menu a {
            display: block;
            padding: 12px 15px;
            color: #000;
            font-weight: 600;
            text-decoration: none;
            border-radius: 10px;
            transition: 0.3s;
            margin-bottom: 10px;
        }

        .sidebar-menu a:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            width: 100%;
        }

        .filter-menu {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .filter-menu a {
            padding: 10px 20px;
            background: rgba(255,255,255,0.6);
            border-radius: 20px;
            text-decoration: none;
            color: #333;
            font-weight: 600;
            border: 1px solid rgba(0,0,0,0.05);
            transition: 0.3s;
        }

        .filter-menu a:hover {
            background: #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
                }

        .vendor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        .vendor-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: left;
        }

        .img-placeholder {
            width: 100%;
            height: 180px;
            border-radius: 15px;
            margin-bottom: 15px;
            background-size: cover;
            background-position: center;
            background-color: #ddd;
        }

        .v-title {
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 5px 0;
        }

        .v-badge {
            display: inline-block;
            padding: 5px 12px;
            background: #f3d1e0;
            color: #000;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .v-info {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 5px;
            color: #444;
        }

        .btn-zakazi {
            display: block;
            width: 100%;
            padding: 12px;
            background: #fdfbfb;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 15px;
            transition: 0.3s;
        }

        .btn-zakazi:hover {
            background: #000;
            color: #fff;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(5px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #f6f3f0;
            width: 90%;
            max-width: 550px;
            max-height: 90vh;
            overflow-y: auto;
            border-radius: 20px;
            padding: 30px;
            position: relative;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 24px;
            cursor: pointer;
            border: none;
            background: none;
            font-weight: bold;
        }

        .modal-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .modal-subtitle {
            color: #888;
            font-size: 14px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .modal-box {
            background: rgba(243, 209, 224, 0.3);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .modal-label {
            font-size: 13px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
        }

        .modal-input, .modal-select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 10px;
            background: #fff;
            font-family: 'Montserrat';
            font-weight: 500;
            margin-bottom: 15px;
            box-sizing: border-box;
        }

        .custom-calendar {
            background: #fff;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .cal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .cal-header button {
            background: #f4f4f4;
            border: none;
            padding: 5px 10px;
            border-radius: 5px;
            font-weight: 600;
            cursor: pointer;
        }

        .cal-weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            color: #888;
            margin-bottom: 10px;
        }

        .cal-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
        }

        .cal-day {
            padding: 8px 0;
            text-align: center;
            border-radius: 8px;
            border: 1px solid #eee;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .cal-day.green {
            border-color: #2a9d8f;
            background: #e9f5f4;
            color: #1e7066;
        }

        .cal-day.red {
            border-color: #f4f4f4;
            background: #f9f9f9;
            color: #ccc;
            cursor: not-allowed;
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            margin-top: 4px;
        }

        .dot.green {
            background: #2a9d8f;
        }

        .dot.red {
            background: #e63946;
        }

        .cal-day.selected {
            border: 2px solid #000 !important;
            background: #f3d1e0 !important;
            color: #000 !important;
        }

        .event-card {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

        .event-card input[type="radio"] {
            transform: scale(1.3);
        }

        .btn-submit-modal {
            width: 100%;
            background: #000;
            color: #fff;
            border: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
        }

        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.3);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 700;
                color: #000;
                text-transform: uppercase;
                margin: 0;
            }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #000;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-nav-container {
                display: none;
                width: 100%;
                margin-top: 20px;
                flex-direction: column;
            }

            .sidebar-nav-container.active {
                display: flex;
            }

            .sidebar-menu a {
                padding: 12px;
                text-align: center;
                font-size: 15px;
                background: rgba(255, 255, 255, 0.4);
            }

            .main-content {
                padding: 20px 15px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">EventDreamer</h2>
            </div>
            <div class="logo-text">EventDreamer</div>
            <div class="sidebar-nav-container" id="navContainer">
                <ul class="sidebar-menu">
                    <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                    <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")">🎉 Moji događaji</a></li>
                    <li><a href="@Url.Action("Index", "Guests")">👥 Lista gostiju</a></li>
                    <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i troškovi</a></li>
                    <li><a href="#" style="background: rgba(255, 255, 255, 0.6);">📸 Pronađi vendore</a></li>
                    <li><a href="@Url.Action("Logout", "Account")" style="background: #ffccd5; margin-top: 30px;">Odjavi se</a></li>
                </ul>
            </div>
        </div>

        <div class="main-content">
            @if (TempData["Poruka"] != null)
            {
                <div style="background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; font-weight: 600; margin-bottom: 20px; border: 1px solid #c3e6cb;">
                    @TempData["Poruka"]
                </div>
            }

            <div class="filter-menu">
                <a href="@Url.Action("Index", new { kId = 0 })">Svi vendori</a>
                <a href="@Url.Action("Index", new { kId = 1 })">Sale i restorani</a>
                <a href="@Url.Action("Index", new { kId = 2 })">Fotografi</a>
                <a href="@Url.Action("Index", new { kId = 3 })">Muzika / bend</a>
                <a href="@Url.Action("Index", new { kId = 4 })">Dekoracija</a>
                <a href="@Url.Action("Index", new { kId = 5 })">Torte i slatkiši</a>
            </div>

            <div class="vendor-grid">
                @if (Model != null && Model.Any())
                {
                    foreach (var v in Model)
                    {
                        <div class="vendor-card">
                            <div class="img-placeholder" style="background-image: url('@v.ImagePath');"></div>
                            <h3 class="v-title">@v.Name</h3>
                            <div class="v-badge">@(v.VendorCategory != null ? v.VendorCategory.CategoryName : "Bez kategorije")</div>
                            <div class="v-info"><strong>Kontakt:</strong> @v.Contact</div>
                            <div class="v-info">
                                <strong>Cijena:</strong> @v.BasePrice €
                                @if (v.CategoryID == 1)
                                {<span style="font-size: 11px; color: #666;">/ po osobi</span>}
                            </div>

                            <button type="button" class="btn-zakazi" onclick="otvoriModal(@v.Id, '@v.Name.Replace("'", "\\'")', '@v.BasePrice', @v.CategoryID)">Zakaži termin</button>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1 / -1; text-align: center; font-weight: 600; padding: 40px;">Trenutno nema vendora u ovoj kategoriji.</div>
                }
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="bookingModal">
        <div class="modal-content">
            <button class="close-modal" onclick="zatvoriModal()">×</button>
            <h2 class="modal-title" id="modalVendorName">Zakaži</h2>
            <div class="modal-subtitle" id="modalVendorPrice">Osnovna cijena: 0.00 €</div>

            <form action="@Url.Action("PosaljiUpit", "Vendors")" method="post" id="bookingForm">
                <input type="hidden" name="vendorId" id="hiddenVendorId" />
                <input type="hidden" name="datum" id="hiddenDatum" required />

                <div class="modal-box" id="paketContainer" style="display: none;">
                    <label class="modal-label">Odaberite paket usluga:</label>
                    <select name="odabraniPaket" id="paketSelect" class="modal-select" onchange="racunajCijenu()">
                        <option value="premium">💍 Svadbeni paket (Premium)</option>
                        <option value="standard">🎂 Rođendanski paket (Standard)</option>
                        <option value="poslovni">💼 Poslovni paket</option>
                    </select>

                    <label class="modal-label">Unesite broj gostiju:</label>
                    <input type="number" name="brojGostiju" id="brojGostijuInput" class="modal-input" placeholder="Npr. 150" oninput="racunajCijenu()" />

                    <div id="ukupnaCijenaPrikaz" style="margin-top: 10px; color: #111; font-size: 14px;"></div>
                </div>

                <div class="custom-calendar">
                    <div class="cal-header">
                        <button type="button">&lt; Prethodni</button>
                        <span>📅 Jul 2026.</span>
                        <button type="button">Sljedeći &gt;</button>
                    </div>
                    <div class="cal-weekdays">
                        <span>PON</span><span>UTO</span><span>SRI</span><span>ČET</span><span>PET</span><span>SUB</span><span>NED</span>
                    </div>
                    <div class="cal-days" id="calendarDays"></div>
                </div>

                <h3 style="font-size: 16px; margin-bottom: 10px;">Izaberi događaj za koji rezervišeš:</h3>
                @if (dogadjaji != null && dogadjaji.Any())
                {
                    foreach (var dogadjaj in dogadjaji)
                    {
                        <label class="event-card">
                            <div>
                                <strong style="display:block; margin-bottom:5px;">@dogadjaj.Title</strong>
                                <span style="font-size: 12px; color: #888;">Trenutni datum: 📅 @(dogadjaj.Date.HasValue ? dogadjaj.Date.Value.ToString("dd.MM.yyyy") : "Nije određeno")</span>
                            </div>
                            <input type="radio" name="eventId" value="@dogadjaj.Id" required />
                        </label>
                    }
                }
                else
                {
                    <div style="color: #e63946; font-size: 13px; font-weight: 600; margin-bottom: 15px;">
                        ⚠️ Niste kreirali nijedan događaj!!
                    </div>
                }

                <button type="button" class="btn-submit-modal" onclick="provjeriIposalji()">POTVRDI I DODAJ U BUDŽET</button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            document.getElementById("navContainer").classList.toggle("active");
            this.innerHTML = this.innerHTML === "☰" ? "✕" : "☰";
        });

        let currentCategoryId = 0;
        let currentBasePrice = 0;

        function otvoriModal(id, naziv, cijenaStr, categoryId) {
            currentCategoryId = categoryId;
            // prebacivanje cijene iz stringa u broj 
            currentBasePrice = parseFloat(cijenaStr.toString().replace(',', '.'));

            document.getElementById('hiddenVendorId').value = id;
            document.getElementById('modalVendorName').innerText = 'Zakaži: ' + naziv;

            let subtitle = document.getElementById('modalVendorPrice');
            let paketContainer = document.getElementById('paketContainer');
            let brojGostijuInput = document.getElementById('brojGostijuInput');

            if (categoryId === 1) {
                subtitle.innerText = 'Početna cijena menija: ' + currentBasePrice + ' € / osobi';
                paketContainer.style.display = 'block';
                brojGostijuInput.required = true;
                racunajCijenu();
            } else {
                subtitle.innerText = 'Fiksna cijena usluge: ' + currentBasePrice + ' €';
                paketContainer.style.display = 'none';
                brojGostijuInput.required = false;
                document.getElementById('ukupnaCijenaPrikaz').innerHTML = '';
            }

            document.getElementById('bookingModal').style.display = 'flex';
        }

        function zatvoriModal() {
            document.getElementById('bookingModal').style.display = 'none';
        }

        function racunajCijenu() {
            if (currentCategoryId !== 1) return;

            let brojGostiju = document.getElementById('brojGostijuInput').value;
            let paket = document.getElementById('paketSelect').value;
            let prikaz = document.getElementById('ukupnaCijenaPrikaz');

            if (!brojGostiju || brojGostiju <= 0) {
                prikaz.innerHTML = '';
                return;
            }

            let cijenaPoOsobi = currentBasePrice;
            if (paket === 'standard') cijenaPoOsobi = Math.max(15, currentBasePrice - 10);
            else if (paket === 'poslovni') cijenaPoOsobi = Math.max(10, currentBasePrice - 15);

            let ukupno = cijenaPoOsobi * brojGostiju;
            prikaz.innerHTML = 'Ukupna procijenjena cijena: <strong>' + ukupno.toFixed(2) + ' €</strong>';
        }

        const calendarDaysContainer = document.getElementById('calendarDays');
        calendarDaysContainer.innerHTML = '<div></div><div></div>';
        for (let i = 1; i <= 31; i++) {
            let isZauzet = (i === 1 || i === 2 || i === 15 || i === 22);
            let klasa = isZauzet ? 'red' : 'green';
            calendarDaysContainer.innerHTML += `
                    <div class="cal-day ${klasa}" onclick="odaberiDatum(this, ${i}, ${isZauzet})">
                        ${i}.<div class="dot ${klasa}"></div>
                    </div>`;
        }

        function odaberiDatum(element, dan, isZauzet) {
            if (isZauzet) { alert("Termin je zauzet! Izaberite zeleni datum."); return; }
            document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
            element.classList.add('selected');
            let danFormat = dan < 10 ? '0' + dan : dan;
            document.getElementById('hiddenDatum').value = `2026-07-${danFormat}`;
        }

        function provjeriIposalji() {
            let datum = document.getElementById('hiddenDatum').value;
            let dogadjaji = document.getElementsByName('eventId');
            let izabran = Array.from(dogadjaji).some(r => r.checked);

            if (!datum) alert("Odaberite datum iz kalendara!");
            else if (!izabran && dogadjaji.length > 0) alert("Izaberite događaj!");
            else document.getElementById('bookingForm').submit();
        }
    </script>
</body>
</html>