@model IEnumerable<EventDreamer.Models.Vendor>
@{
    Layout = null;
    // Sada preuzimamo prave SQL događaje
    var dogadjaji = ViewBag.MojiDogadjaji as List<EventDreamer.Models.Event>;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Pretraga Vendora - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            background: #f4eade;
        }

        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.4)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100%;
            display: flex;
        }

        .sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.3);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
        }

            .sidebar .logo-text {
                font-size: 22px;
                font-weight: 700;
                color: #000;
                margin-bottom: 40px;
                text-transform: uppercase;
            }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .sidebar-menu a {
                display: block;
                padding: 12px 15px;
                color: #000;
                font-weight: 600;
                text-decoration: none;
                border-radius: 10px;
                transition: 0.3s;
                margin-bottom: 10px;
            }

                .sidebar-menu a:hover {
                    background: rgba(255, 255, 255, 0.6);
                }

        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
        }

        .filter-menu {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

            .filter-menu a {
                padding: 10px 20px;
                background: rgba(255,255,255,0.6);
                border-radius: 20px;
                text-decoration: none;
                color: #333;
                font-weight: 600;
                border: 1px solid rgba(0,0,0,0.05);
            }

                .filter-menu a:hover {
                    background: #fff;
                }

        .vendor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        .vendor-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: left;
        }

        .img-placeholder {
            width: 100%;
            height: 180px;
            border-radius: 15px;
            margin-bottom: 15px;
            background-size: cover;
            background-position: center;
        }

        .v-title {
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 5px 0;
        }

        .v-badge {
            display: inline-block;
            padding: 5px 12px;
            background: #f3d1e0;
            color: #000;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .v-info {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 5px;
            color: #444;
        }

        .btn-zakazi {
            display: block;
            width: 100%;
            padding: 12px;
            background: #fdfbfb;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 15px;
            transition: 0.3s;
        }

            .btn-zakazi:hover {
                background: #000;
                color: #fff;
            }

        /* MODAL (ISKAČUĆI KALENDAR) */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(5px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #f6f3f0;
            width: 90%;
            max-width: 550px;
            max-height: 90vh;
            overflow-y: auto;
            border-radius: 20px;
            padding: 30px;
            position: relative;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 24px;
            cursor: pointer;
            border: none;
            background: none;
            font-weight: bold;
        }

        .modal-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .modal-subtitle {
            color: #888;
            font-size: 14px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .modal-box {
            background: rgba(243, 209, 224, 0.3);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .modal-label {
            font-size: 13px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
        }

        .modal-input {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 10px;
            background: #fff;
            font-family: 'Montserrat';
            font-weight: 500;
            margin-bottom: 15px;
            box-sizing: border-box;
        }

        .custom-calendar {
            background: #fff;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .cal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
            margin-bottom: 15px;
        }

            .cal-header button {
                background: #f4f4f4;
                border: none;
                padding: 5px 10px;
                border-radius: 5px;
                font-weight: 600;
                cursor: pointer;
            }

        .cal-weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            color: #888;
            margin-bottom: 10px;
        }

        .cal-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
        }

        .cal-day {
            padding: 8px 0;
            text-align: center;
            border-radius: 8px;
            border: 1px solid #eee;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .cal-day.green {
                border-color: #2a9d8f;
                background: #e9f5f4;
                color: #1e7066;
            }

            .cal-day.red {
                border-color: #f4f4f4;
                background: #f9f9f9;
                color: #ccc;
                cursor: not-allowed;
            }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            margin-top: 4px;
        }

            .dot.green {
                background: #2a9d8f;
            }

            .dot.red {
                background: #e63946;
            }

        .cal-day.selected {
            border: 2px solid #000 !important;
            background: #f3d1e0 !important;
            color: #000 !important;
        }

        .event-card {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

            .event-card input[type="radio"] {
                transform: scale(1.3);
            }

        .btn-submit-modal {
            width: 100%;
            background: #000;
            color: #fff;
            border: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="sidebar">
            <div class="logo-text">EventDreamer</div>
            <ul class="sidebar-menu">
                <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                <li><a href="@Url.Action("MyEvents", "Dashboard")">🎉 Moji Događaji</a></li>
                <li><a href="@Url.Action("Index", "Guests")">👥 Lista Gostiju</a></li>
                <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i Troškovi</a></li>
                <li><a href="#" style="background: rgba(255, 255, 255, 0.6);">📸 Pronađi Vendore</a></li>
                <li><a href="@Url.Action("Index", "Home")" style="background: #ffccd5; margin-top: 50px;">Odjavi se</a></li>
            </ul>
        </div>
        <div class="main-content">

            @if (TempData["Poruka"] != null)
            {
                <div style="background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; font-weight: 600; margin-bottom: 20px; border: 1px solid #c3e6cb;">
                    ✅ @TempData["Poruka"]
                </div>
            }

            <div class="filter-menu">
                <a href="@Url.Action("Index", new { pretragaKategorije = "Sve" })">Svi vendori</a>
            </div>

            <div class="vendor-grid">
                @if (Model != null && Model.Any())
                {
                    foreach (var v in Model)
                    {
                        <div class="vendor-card">
                            <div class="img-placeholder" style="background-image: url('@v.ImagePath');"></div>
                            <h3 class="v-title">@v.Name</h3>
                            <div class="v-badge">@(v.VendorCategory != null ? v.VendorCategory.CategoryName : "Bez kategorije")</div>
                            <div class="v-info"><strong>Kontakt:</strong> @v.Contact</div>
                            <div class="v-info"><strong>Cijena:</strong> @v.BasePrice €</div>

                            <button type="button" class="btn-zakazi" onclick="otvoriModal(@v.Id, '@v.Name', '@v.BasePrice')">Zakaži termin</button>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1 / -1; text-align: center; font-weight: 600; padding: 40px;">Trenutno nema odobrenih saradnika u bazi.</div>
                }
            </div>

        </div>
    </div>

    <div class="modal-overlay" id="bookingModal">
        <div class="modal-content">
            <button class="close-modal" onclick="zatvoriModal()">×</button>
            <h2 class="modal-title" id="modalVendorName">Zakaži: Restoran</h2>
            <div class="modal-subtitle" id="modalVendorPrice">Osnovna cijena: 0.00 €</div>

            <form action="@Url.Action("PosaljiUpit", "Vendors")" method="post" id="bookingForm">
                <input type="hidden" name="vendorId" id="hiddenVendorId" />
                <input type="hidden" name="datum" id="hiddenDatum" required />

                <div class="modal-box">
                    <label class="modal-label">Unesite procijenjen broj gostiju:</label>
                    <input type="number" name="brojGostiju" class="modal-input" placeholder="Npr. 150" required />
                </div>

                <div class="custom-calendar">
                    <div class="cal-header">
                        <button type="button">&lt; Prethodni</button>
                        <span>📅 Jul 2026.</span>
                        <button type="button">Sljedeći &gt;</button>
                    </div>
                    <div class="cal-weekdays">
                        <span>PON</span><span>UTO</span><span>SRI</span><span>ČET</span><span>PET</span><span>SUB</span><span>NED</span>
                    </div>
                    <div class="cal-days" id="calendarDays">
                    </div>
                </div>

                <h3 style="font-size: 16px; margin-bottom: 10px;">Izaberi za koji SVOJ događaj rezervišeš:</h3>
                @if (dogadjaji != null && dogadjaji.Any())
                {
                    foreach (var dogadjaj in dogadjaji)
                    {
                        <label class="event-card">
                            <div>
                                <strong style="display:block; margin-bottom:5px;">@dogadjaj.Title</strong>
                                <span style="font-size: 12px; color: #888;">Trenutni datum: 📅 @(dogadjaj.Date.HasValue ? dogadjaj.Date.Value.ToString("dd.MM.yyyy") : "Nije određeno")</span>
                            </div>
                            <input type="radio" name="dogadjajNaziv" value="@dogadjaj.Title" required />
                        </label>
                    }
                }
                else
                {
                    <div style="color: #e63946; font-size: 13px; font-weight: 600; margin-bottom: 15px;">
                        ⚠️ Niste kreirali nijedan događaj na tabli "Moji Događaji"!
                    </div>
                }

                <button type="button" class="btn-submit-modal" onclick="provjeriIposalji()">POŠALJI UPIT</button>
            </form>
        </div>
    </div>

    <script>
        function otvoriModal(id, naziv, cijena) {
            document.getElementById('hiddenVendorId').value = id;
            document.getElementById('modalVendorName').innerText = 'Zakaži: ' + naziv;
            document.getElementById('modalVendorPrice').innerText = 'Osnovna cijena: ' + cijena + ' €';
            document.getElementById('bookingModal').style.display = 'flex';
        }

        function zatvoriModal() {
            document.getElementById('bookingModal').style.display = 'none';
        }

        const calendarDaysContainer = document.getElementById('calendarDays');
        calendarDaysContainer.innerHTML = '<div></div><div></div>';

        for (let i = 1; i <= 31; i++) {
            let isZauzet = (i === 1 || i === 2 || i === 3 || i === 15 || i === 22);
            let klasa = isZauzet ? 'red' : 'green';

            calendarDaysContainer.innerHTML += `
                    <div class="cal-day ${klasa}" onclick="odaberiDatum(this, ${i}, ${isZauzet})">
                        ${i}.
                        <div class="dot ${klasa}"></div>
                    </div>
                `;
        }

        function odaberiDatum(element, dan, isZauzet) {
            if (isZauzet) {
                alert("Ovaj termin je nažalost zauzet! Izaberite zeleni datum.");
                return;
            }
            let sviDani = document.querySelectorAll('.cal-day');
            sviDani.forEach(d => d.classList.remove('selected'));
            element.classList.add('selected');
            document.getElementById('hiddenDatum').value = dan + ". Jul 2026.";
        }

        function provjeriIposalji() {
            let datum = document.getElementById('hiddenDatum').value;
            let radioButtons = document.getElementsByName('dogadjajNaziv');
            let izabranDogadjaj = false;

            for (let i = 0; i < radioButtons.length; i++) {
                if (radioButtons[i].checked) izabranDogadjaj = true;
            }

            if (!datum) {
                alert("Molimo Vas da prvo odaberete slobodan (zeleni) datum iz kalendara!");
            } else if (!izabranDogadjaj && radioButtons.length > 0) {
                alert("Molimo Vas da izaberete za koji događaj rezervišete termin!");
            } else {
                document.getElementById('bookingForm').submit();
            }
        }
    </script>
</body>
</html>