@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Prijava - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            color: #333;
        }

        .auth-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            width: 100%;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.15);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            text-align: center;
            color: #111;
        }

        .auth-card h2 {
            margin-bottom: 25px;
            font-weight: 600;
            letter-spacing: 1px;
            color: #111;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #111;
        }

        .input-group input {
             width: 100%;
             padding: 14px 15px;
             background: rgba(255, 255, 255, 0.5);
             border: 1px solid rgba(255, 255, 255, 0.6);
             border-radius: 12px;
             font-size: 1rem;
             color: #222;
             outline: none;
             transition: all 0.3s ease;
        }

        .input-group input:focus {
             background: rgba(255, 255, 255, 0.8);
             border-color: #fff;
             box-shadow: 0 0 15px rgba(255, 255, 255, 0.5);
        }

        .auth-btn {
            width: 100%;
            padding: 14px;
            background: var(--logo-pink);
            color: #222;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 15px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .auth-btn:hover {
            background: var(--logo-green);
            color: #222;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .auth-link {
            display: inline-block;
            margin-top: 20px;
            color: #111;
            font-size: 0.9rem;
            text-decoration: none;
            font-weight: 500;
        }

        .auth-link:hover {
            text-decoration: underline;
        }

        /* responsive za mobilne telefone*/
        @@media (max-width: 480px) {
            .auth-container {
                padding: 15px;
            }

            .auth-card {
                padding: 30px 20px !important;
                width: 92% !important;
                max-width: 340px !important;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            }

            .auth-card h2 {
                font-size: 1.5rem !important;
                margin-bottom: 20px;
            }

            .input-group {
                margin-bottom: 15px;
            }

            .input-group input {
                padding: 12px;
                font-size: 0.95rem;
            }

            .auth-btn {
                padding: 12px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <h2>Prijavi se</h2>
            @if (TempData["PorukaNakonRegistracije"] != null)
            {
                <div style="background-color: var(--logo-green); color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 15px; text-align: center; font-weight: 500; font-size: 0.9rem; ">
                    @TempData["PorukaNakonRegistracije"]
                </div>
            }

            <form action="@Url.Action("Login", "Account")" method="post">
                @Html.AntiForgeryToken() <div class="input-group">
                    <label>Email</label>
                    <input type="email" name="Email" required placeholder="Unesite email" />
                </div>
                <div class="input-group">
                    <label>Lozinka</label>
                    <input type="password" name="Password" required placeholder="Unesite lozinku" />
                </div>

                <button type="submit" class="auth-btn">Prijavi se</button>
            </form>

            <a href="@Url.Action("Register", "Account")" class="auth-link">Nemate nalog? <strong>Registrujte se</strong></a>
        </div>
    </div>

</body>
</html>