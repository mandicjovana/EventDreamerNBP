@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Finansijski Izvještaji - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.4);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            box-shadow: 4px 0 24px rgba(0,0,0,0.05);
        }

            .sidebar .logo-text {
                font-size: 22px;
                font-weight: 800;
                color: #111;
                margin-bottom: 40px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 12px;
            }

            .sidebar-menu a {
                display: block;
                padding: 12px 15px;
                color: #333;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: 0.3s;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.8);
                }

                .sidebar-menu a.active {
                    background: #e9f5e9;
                    color: #2a9d8f;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
                }

        .logout-btn {
            background: #ffccd5;
            text-align: center;
            font-weight: 700;
            padding: 12px 15px;
            color: #000;
            text-decoration: none;
            border-radius: 12px;
            transition: 0.3s;
        }

            .logout-btn:hover {
                background: #ffb3c1;
            }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
        }

        .page-title {
            text-align: center;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 40px;
            color: #111;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            text-align: center;
        }

            .glass-panel h3 {
                margin: 0 0 15px 0;
                font-size: 16px;
                color: #555;
                text-transform: uppercase;
                font-weight: 700;
                letter-spacing: 1px;
            }

            .glass-panel .number {
                font-size: 50px;
                font-weight: 800;
                font-family: 'Arial Black', sans-serif;
                letter-spacing: -1px;
            }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="logo-text">⚙️ Admin Sistem</div>
            <ul class="sidebar-menu">
                <li><a href="@Url.Action("Index", "Admin")">📊 Kontrolna Tabla</a></li>
                <li><a href="@Url.Action("ManageUsers", "Admin")">👥 Svi korisnici</a></li>
                <li><a href="@Url.Action("ManageVendors", "Admin")">🏪 Vendori</a></li>
                <li><a href="@Url.Action("Reports", "Admin")" class="active">📈 Finansije</a></li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn">Odjavi se</a>
        </div>

        <div class="main-content">
            <div class="page-title">📈 Detaljni finansijski izvještaji</div>

            <div class="stats-grid">
                <div class="glass-panel">
                    <h3>Ukupno Registrovanih Korisnika</h3>
                    <div class="number" style="color:#000;">@ViewBag.UkupnoKorisnika</div>
                </div>
                <div class="glass-panel">
                    <h3>Kreiranih Događaja / Proslava</h3>
                    <div class="number" style="color:#d81b60;">@ViewBag.UkupnoDogadjaja</div>
                </div>
                <div class="glass-panel">
                    <h3>Ukupan Broj Gostiju u Bazi</h3>
                    <div class="number" style="color:#2e7d32;">@ViewBag.UkupnoGostiju</div>
                </div>
                <div class="glass-panel">
                    <h3>Ukupan Obrt Novca (Svi budžeti)</h3>
                    <div class="number" style="color:#f4a261;">@ViewBag.UkupnoTroskova €</div>
                </div>
            </div>

        </div>
    </div>
</body>
</html>