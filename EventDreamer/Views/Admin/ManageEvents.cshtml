@model IEnumerable<EventDreamer.Models.Event>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin događaji - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        /* SIDEBAR */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: block;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 8px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 18px;
                color: #444;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: all 0.3s ease;
                font-size: 14px;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.9);
                    color: #111;
                    transform: translateX(4px);
                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
                }

                .sidebar-menu a.active {
                    background: #111;
                    color: #fff;
                    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
                    transform: translateX(4px);
                }

        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .logout-btn:hover {
                background: var(--logo-green);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        .btn-add, .btn-trigger-form, .btn-submit-modal {
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            padding: 12px 25px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
            display: inline-block;
        }

            .btn-add:hover, .btn-trigger-form:hover, .btn-submit-modal:hover {
                background: var(--logo-pink);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        .btn-edit {
            background: var(--logo-green);
            color: #222;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-edit:hover {
                background: var(--logo-pink);
                transform: translateY(-2px);
            }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        .page-title {
            text-align: center;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 30px;
            color: #111;
        }

        .list-container {
            max-width: 1100px;
            margin: 0 auto;
            width: 100%;
        }

        /* 🚀 POPRAVLJENA STRUKTURA GRID-A (Sada ima 4 kolone umjesto 5 jer nema akcije) */
        .list-header {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            padding: 0 30px;
            margin-bottom: 15px;
            font-size: 12px;
            font-weight: 700;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .event-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            align-items: center;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            padding: 15px 30px;
            border-radius: 15px;
            margin-bottom: 15px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            transition: 0.3s;
        }

            .event-row:hover {
                background: rgba(255, 255, 255, 0.9);
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
            }

        .e-title {
            font-weight: 800;
            color: #111;
            font-size: 16px;
            margin-bottom: 5px;
        }

        .e-user {
            color: #2a9d8f;
            font-weight: 700;
            font-size: 13px;
        }

        .e-date {
            color: #555;
            font-weight: 600;
            font-size: 14px;
        }

        .e-budget-box {
            background: #fff;
            padding: 8px 12px;
            border-radius: 10px;
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
            display: inline-block;
        }

        .e-planned {
            font-size: 11px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .e-actual {
            font-size: 15px;
            font-weight: 800;
        }

        /* RESPONSIVE */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

                .sidebar .logo-text {
                    display: none;
                }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

                .mobile-header .logo-text-mobile {
                    font-size: 20px;
                    font-weight: 800;
                    color: #111;
                    text-transform: uppercase;
                    margin: 0;
                }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

                .sidebar-menu.active {
                    display: flex;
                }

                .sidebar-menu a {
                    justify-content: center;
                    transform: none !important;
                }

                    .sidebar-menu a:hover:not(.active) {
                        transform: none !important;
                    }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .page-title {
                font-size: 22px;
                margin-bottom: 25px;
            }

            .list-header {
                display: none;
            }

            .event-row {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
                padding: 20px;
                position: relative;
            }

            .e-title {
                font-size: 18px;
                margin-bottom: 2px;
            }

            .mobile-action-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                width: 100%;
                margin-top: 10px;
                border-top: 1px dashed rgba(0, 0, 0, 0.1);
                padding-top: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">⚙️ Admin</h2>
            </div>

            <div class="logo-text">⚙️ Admin sistem</div>
            <ul class="sidebar-menu" id="navContainer">
                <li><a href="@Url.Action("Index", "Admin")">📊 Statistika</a></li>
                <li><a href="@Url.Action("ManageUsers", "Admin")">👥 Svi korisnici</a></li>
                <li><a href="@Url.Action("ManageVendors", "Admin")">🏪 Vendori</a></li>
                <li><a href="@Url.Action("ManageEvents", "Admin")" class="active">📅 Svi događaji</a></li>
                <li><a href="@Url.Action("Index", "Home")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a></li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn desktop-only">Odjavi se</a>
        </div>

        <div class="main-content">
            <div class="list-container">
                <div class="page-title">Svi kreirani događaji u sistemu</div>

                @if (TempData["Poruka"] != null)
                {
                    <div style="background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; font-weight: 600; margin-bottom: 20px; border: 1px solid #c3e6cb;">
                        ✅ @TempData["Poruka"]
                    </div>
                }
                @if (TempData["Greska"] != null)
                {
                    <div style="background: #f8d7da; color: #721c24; padding: 15px 20px; border-radius: 10px; font-weight: 600; margin-bottom: 20px; border: 1px solid #f5c6cb;">
                        ⚠️ @TempData["Greska"]
                    </div>
                }

                <div class="list-header">
                    <div>NAZIV DOGAĐAJA I KORISNIK</div>
                    <div>LOKACIJA</div>
                    <div>DATUM</div>
                    <div>FINANSIJE</div>
                </div>

                @if (Model != null && Model.Any())
                {
                    foreach (var e in Model)
                    {
                        decimal ukupnoPotroseno = e.Expenses != null ? e.Expenses.Sum(ex => ex.ActualAmount) : 0;
                        bool prekoraceno = ukupnoPotroseno > e.TotalBudget;

                        <div class="event-row">
                            <div>
                                <div class="e-title">@e.Title</div>
                                <div class="e-user">👤 @(e.User != null ? e.User.FirstName + " " + e.User.LastName : "Nepoznat")</div>
                            </div>
                            <div class="e-date">📍 @e.Location</div>
                            <div class="e-date">📅 @(e.Date.HasValue ? e.Date.Value.ToString("dd.MM.yyyy") : "Nije zakazano")</div>

                            <div class="mobile-action-row">
                                <div class="e-budget-box">
                                    <div class="e-planned">Budžet: @e.TotalBudget €</div>
                                    <div class="e-actual" style="color: @(prekoraceno ? "#e63946" : "#2a9d8f");">Trošak: @ukupnoPotroseno €</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; padding: 30px; background: rgba(255,255,255,0.6); border-radius: 15px; font-weight: 600;">
                        Trenutno nema kreiranih događaja.
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            if (nav.classList.contains("active")) {
                this.innerHTML = "✕";
                mobileLogout.style.display = "flex";
            } else {
                this.innerHTML = "☰";
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>