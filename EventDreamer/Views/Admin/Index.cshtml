@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin Statistika - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        /* za svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm { 
            width: 16px; 
            height: 16px; 
        }
        .icon-md { 
            width: 20px; 
            height: 20px; 
        }
        .icon-lg { 
            width: 28px;
            height: 28px;
        }
        .icon-xl { 
            width: 34px; 
            height: 34px; 
        }

        /* za sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: #111;
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: #111;
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* dugmici u logo bojama */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        .main-stats {
            display: flex;
            gap: 30px;
            margin-bottom: 50px;
            justify-content: center;
        }

        .stat-card-large {
            width: 45%;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .stat-card-large:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.9);
        }

        .icon-circle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
        }

        .icon-circle.pink {
            background: var(--logo-pink);
            color: #d81b60;
        }

        .icon-circle.green {
            background: var(--logo-green);
            color: #2e7d32;
        }

        .stat-title {
            font-size: 18px;
            font-weight: 700;
            color: #444;
            margin-bottom: 15px;
        }

        .stat-number {
            font-size: 60px;
            font-weight: 800;
            color: #000;
            line-height: 1;
            font-family: 'Arial Black', sans-serif;
            letter-spacing: -2px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 30px;
            color: #222;
            text-align: center;
        }

        .vendor-stats {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .stat-card-small {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 25px 30px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            min-width: 140px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
        }

        .stat-card-small:hover {
            transform: translateY(-3px);
            background: rgba(255, 255, 255, 0.9);
        }

        .stat-card-small .icon {
            margin-bottom: 10px;
            color: #555;
            display: flex;
        }

        .stat-card-small .title {
            font-size: 14px;
            font-weight: 700;
            color: #444;
            margin-bottom: 10px;
        }

        .stat-card-small .num {
            font-size: 36px;
            font-weight: 800;
            font-family: 'Arial Black', sans-serif;
            letter-spacing: -1px;
            margin-top: auto;
        }

        /* responsive dizajn */
        @@media screen and (max-width: 768px) {
            .bg-image { 
                flex-direction: column;
            }
            .sidebar { 
                width: 100% !important; 
                border-right: none; 
                border-bottom: 1px solid rgba(255, 255, 255, 0.4); 
                padding: 15px 20px; 
            }
            .sidebar .logo-text { 
                display: none; 
            }
            .mobile-header { 
                display: flex; 
                justify-content: flex-start; 
                align-items: center; 
                width: 100%; 
                gap: 15px; 
            }
            .mobile-header .logo-text-mobile { 
                font-size: 20px; 
                font-weight: 800; 
                color: #111; 
                text-transform: uppercase; 
                margin: 0; 
                display: flex; 
                align-items: center; 
                gap: 8px;
            }
            .hamburger-btn { 
                background: none; 
                border: none; 
                cursor: pointer; 
                color: #111; 
                padding: 0; 
                display: flex; 
                align-items: center;
            }
            .sidebar-menu { 
                display: none; 
                flex-direction: column; 
                width: 100%; 
                margin-top: 20px; 
            }
            .sidebar-menu.active { 
                display: flex; 
            }
            .sidebar-menu a { 
                justify-content: center; 
                transform: none !important; 
            }
            .sidebar-menu a:hover:not(.active) { 
                transform: none !important; 
            }
            .logout-btn.desktop-only { 
                display: none; 
            }
            .logout-btn.mobile-only { 
                display: flex; 
                margin-top: 10px; 
            }
            .main-content { 
                padding: 30px 15px;
            }
            .main-stats { 
                flex-direction: column; 
                gap: 20px; 
                margin-bottom: 30px; 
            }
            .stat-card-large { 
                width: 100%; 
                padding: 30px 20px; 
            }
            .vendor-stats { 
                flex-direction: column;
                gap: 15px; 
            }
            .stat-card-small { 
                width: 100%; 
                display: flex; 
                flex-direction: row; 
                align-items: center; 
                justify-content: space-between; 
                padding: 15px 20px; 
            }
            .stat-card-small .icon { 
                margin: 0; 
            }
            .stat-card-small .title { 
                margin: 0; 
                font-size: 16px; 
                flex: 1; 
                text-align: left; 
                padding-left: 15px; 
            }
            .stat-card-small .num { 
                font-size: 24px; 
                margin: 0; 
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    Admin
                </h2>
            </div>

            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                Admin sistem
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Admin")" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg> Statistika
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageUsers", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg> Svi korisnici
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageVendors", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 3h18v4l-1.5 9h-15L3 7z"></path><line x1="12" y1="16" x2="12" y2="22"></line><line x1="8" y1="22" x2="16" y2="22"></line></svg> Vendori
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageEvents", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> Svi događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Home")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            <div class="main-stats">
                <div class="stat-card-large" onclick="location.href='@Url.Action("ManageUsers", "Admin")'">
                    <div class="icon-circle pink">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <div class="stat-title">Ukupno korisnika</div>
                    <div class="stat-number">@ViewBag.UkupnoKorisnika</div>
                </div>
                <div class="stat-card-large" onclick="location.href='@Url.Action("ManageEvents", "Admin")'">
                    <div class="icon-circle green">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </div>
                    <div class="stat-title">Kreiranih događaja</div>
                    <div class="stat-number">@ViewBag.UkupnoDogadjaja</div>
                </div>
            </div>

            <div class="section-title">Pregled usluga i vendora</div>
            <div class="vendor-stats">
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin", new { filterKategorijaId = 1 })'">
                    <div class="icon">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><path d="M3 21h18" /><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16" /><path d="M9 21v-4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4" /></svg>
                    </div>
                    <div class="title">Sale / restorani</div>
                    <div class="num">@ViewBag.BrojRestorana</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin", new { filterKategorijaId = 2 })'">
                    <div class="icon">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>
                    </div>
                    <div class="title">Fotografi</div>
                    <div class="num">@ViewBag.BrojFotografa</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin", new { filterKategorijaId = 3 })'">
                    <div class="icon">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" /></svg>
                    </div>
                    <div class="title">Muzika</div>
                    <div class="num">@ViewBag.BrojMuzike</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin", new { filterKategorijaId = 4 })'">
                    <div class="icon">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    </div>
                    <div class="title">Dekoracija</div>
                    <div class="num">@ViewBag.BrojDekoracije</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin", new { filterKategorijaId = 5 })'">
                    <div class="icon">
                        <svg class="svg-icon icon-xl" viewBox="0 0 24 24"><path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8" /><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2 1 2 1" /><path d="M2 21h20" /><path d="M12 11v-4" /><path d="M12 3v.01" /></svg>
                    </div>
                    <div class="title">Torte</div>
                    <div class="num">@ViewBag.BrojTorti</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                // svg ikonica za close
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                // svg ikonica za hamburger meni
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>