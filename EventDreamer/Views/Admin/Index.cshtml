@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Statistika - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.4);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            box-shadow: 4px 0 24px rgba(0,0,0,0.05);
        }

            .sidebar .logo-text {
                font-size: 22px;
                font-weight: 800;
                color: #111;
                margin-bottom: 40px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 12px;
            }

            .sidebar-menu a {
                display: block;
                padding: 12px 15px;
                color: #333;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: 0.3s;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.8);
                }

                .sidebar-menu a.active {
                    background: #e9f5e9;
                    color: #2a9d8f;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
                }

        .logout-btn {
            background: #ffccd5;
            text-align: center;
            font-weight: 700;
            padding: 12px 15px;
            color: #000;
            text-decoration: none;
            border-radius: 12px;
            transition: 0.3s;
        }

            .logout-btn:hover {
                background: #ffb3c1;
            }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
        }

        .main-stats {
            display: flex;
            gap: 30px;
            margin-bottom: 50px;
            justify-content: center;
        }

        /* DODAT CURSOR POINTER ZA KLIK I MALI HOVER EFEKAT */
        .stat-card-large {
            width: 45%;
            background: rgba(255,255,255,0.65);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            border: 1px solid rgba(255,255,255,0.9);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

            .stat-card-large:hover {
                transform: translateY(-5px);
                background: rgba(255,255,255,0.8);
            }

        .icon-circle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin: 0 auto 20px auto;
        }

            .icon-circle.pink {
                background: #fce4ec;
                color: #d81b60;
            }

            .icon-circle.green {
                background: #e8f5e9;
                color: #2e7d32;
            }

        .stat-title {
            font-size: 18px;
            font-weight: 700;
            color: #444;
            margin-bottom: 15px;
        }

        .stat-number {
            font-size: 60px;
            font-weight: 800;
            color: #000;
            line-height: 1;
            font-family: 'Arial Black', sans-serif;
            letter-spacing: -2px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 30px;
            color: #222;
            text-align: center;
        }

        .vendor-stats {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        /* I MALE KARTICE REAGUJU NA KLIK I VODE NA VENDORE */
        .stat-card-small {
            background: rgba(255,255,255,0.65);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 25px 30px;
            border: 1px solid rgba(255,255,255,0.9);
            min-width: 140px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            cursor: pointer;
            transition: 0.3s;
        }

            .stat-card-small:hover {
                transform: translateY(-3px);
                background: rgba(255,255,255,0.8);
            }

            .stat-card-small .icon {
                font-size: 30px;
                margin-bottom: 10px;
                color: #555;
            }

            .stat-card-small .title {
                font-size: 14px;
                font-weight: 700;
                color: #444;
                margin-bottom: 10px;
            }

            .stat-card-small .num {
                font-size: 36px;
                font-weight: 800;
                font-family: 'Arial Black', sans-serif;
                letter-spacing: -1px;
            }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="logo-text">⚙️ Admin Sistem</div>
            <ul class="sidebar-menu">
                <li><a href="@Url.Action("Index", "Admin")" class="active">📊 Statistika</a></li>
                <li><a href="@Url.Action("ManageUsers", "Admin")">👥 Svi korisnici</a></li>
                <li><a href="@Url.Action("ManageVendors", "Admin")">🏪 Vendori</a></li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn">Odjavi se</a>
        </div>

        <div class="main-content">
            <div class="main-stats">
                <div class="stat-card-large" onclick="location.href='@Url.Action("ManageUsers", "Admin")'">
                    <div class="icon-circle pink">👥</div>
                    <div class="stat-title">Ukupno korisnika</div>
                    <div class="stat-number">@ViewBag.UkupnoKorisnika</div>
                </div>
                <div class="stat-card-large" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon-circle green">📅</div>
                    <div class="stat-title">Kreiranih događaja</div>
                    <div class="stat-number">@ViewBag.UkupnoDogadjaja</div>
                </div>
            </div>

            <div class="section-title">Pregled usluga i vendora</div>
            <div class="vendor-stats">
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon">🏬</div>
                    <div class="title">Sale / restorani</div>
                    <div class="num">@ViewBag.BrojRestorana</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon">📸</div>
                    <div class="title">Fotografi</div>
                    <div class="num">@ViewBag.BrojFotografa</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon">🎵</div>
                    <div class="title">Muzika</div>
                    <div class="num">@ViewBag.BrojMuzike</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon">✨</div>
                    <div class="title">Dekoracija</div>
                    <div class="num">@ViewBag.BrojDekoracije</div>
                </div>
                <div class="stat-card-small" onclick="location.href='@Url.Action("ManageVendors", "Admin")'">
                    <div class="icon">🎂</div>
                    <div class="title">Torte</div>
                    <div class="num">@ViewBag.BrojTorti</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>