@model IEnumerable<EventDreamer.Models.Vendor>
@{
    Layout = null;
    var kategorije = ViewBag.Kategorije as IEnumerable<EventDreamer.Models.VendorCategory>;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin vendori - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        /* pozadina */
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        .page-title {
            text-align: center;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 30px;
            color: var(--text-dark);
        }

        /* svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .title-icon {
            vertical-align: text-bottom;
            margin-right: 8px;
            width: 28px;
            height: 28px;
        }

        .btn-icon {
            margin-right: 6px;
            vertical-align: middle;
            width: 16px;
            height: 16px;
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
             background: rgba(255, 255, 255, 0.9);
             color: var(--text-dark);
             transform: translateX(4px);
             box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
             background: var(--text-dark);
             color: #fff;
             box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
             transform: translateX(4px);
        }

        /* za dugmice boja sa logoa */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-add, .btn-trigger-form, .btn-submit-modal {
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            padding: 12px 25px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-add:hover, .btn-trigger-form:hover, .btn-submit-modal:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-add {
            height: 43px;
            grid-column: span 2;
        }

        .btn-trigger-form {
            margin-bottom: 30px;
        }

        .btn-edit, .btn-del {
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            display: inline-block;
            text-align: center;
            color: #222;
        }

        .btn-edit {
            background: var(--logo-green);
        }

        .btn-edit:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
        }

        .btn-del {
            background: var(--logo-pink);
        }

        .btn-del:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
        }

        /* za panele i forme */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
        }

        .glass-panel h2 {
            display: flex;
            align-items: center;
            margin-top: 0;
            font-weight: 800;
            font-size: 22px;
            color: #111;
            margin-bottom: 25px;
        }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
        }

        /* za edit modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #fff;
            width: 90%;
            max-width: 500px;
            max-height: 90vh;
            overflow-y: auto;
            border-radius: 20px;
            padding: 30px;
            position: relative;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 24px;
            cursor: pointer;
            border: none;
            background: none;
            font-weight: bold;
        }

        .modal-title {
            display: flex;
            align-items: center;
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            margin-top: 0;
        }

        /* za tabelu vendora */
        .list-container {
            max-width: 1100px;
            margin: 0 auto;
            width: 100%;
        }

        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .glass-table th, .glass-table td {
            padding: 15px 20px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .glass-table th {
            font-weight: 700;
            color: #555;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .vendor-img {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            object-fit: cover;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .v-badge {
            display: inline-block;
            padding: 5px 12px;
            background: var(--logo-pink);
            color: #222;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 0;
        }

        .action-btns {
            display: flex;
            gap: 10px;
            justify-content: flex-start;
        }

        /* za responsive dizajn*/
        .mobile-header {
            display: none;
        }

        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

            .sidebar-menu.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
                transform: none !important;
            }

            .sidebar-menu a:hover:not(.active) {
                transform: none !important;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .glass-panel {
                padding: 20px;
            }

            .btn-trigger-form {
                width: 100%;
                text-align: center;
            }

            .form-inline {
                grid-template-columns: 1fr;
            }

            .btn-add {
                grid-column: span 1 !important;
                width: 100%;
            }

            .glass-table, .glass-table tbody, .glass-table tr, .glass-table td {
                display: block;
                width: 100%;
            }

            .glass-table thead {
                display: none;
            }

            .glass-table tr {
                background: rgba(255, 255, 255, 0.8);
                margin-bottom: 15px;
                border-radius: 15px;
                border: 1px solid rgba(0, 0, 0, 0.1);
                padding: 5px;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            }

            .glass-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-align: right;
                padding: 12px 15px;
                border-bottom: 1px dotted rgba(0, 0, 0, 0.1);
            }

            .glass-table td:last-child {
                border-bottom: none;
            }

            .glass-table td::before {
                content: attr(data-label);
                font-weight: 800;
                font-size: 11px;
                text-transform: uppercase;
                color: #555;
                text-align: left;
                flex-basis: 40%;
            }

            .action-btns {
                justify-content: flex-end;
                width: auto;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    Admin
                </h2>
            </div>

            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                Admin sistem
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                        </svg>
                        Statistika
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageUsers", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        Svi korisnici
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageVendors", "Admin")" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M3 3h18v4l-1.5 9h-15L3 7z"></path>
                            <line x1="12" y1="16" x2="12" y2="22"></line>
                            <line x1="8" y1="22" x2="16" y2="22"></line>
                        </svg>
                        Vendori
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageEvents", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        Svi događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Home")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            @if (ViewBag.IsFiltered != null && (bool)ViewBag.IsFiltered)
            {
                <div class="glass-panel" style="padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 20px;">
                    <h2 style="margin: 0; font-size: 18px;">
                        <svg class="svg-icon title-icon icon-md" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        Prikazujete samo: <span style="color: #2a9d8f; margin-left: 5px;">@ViewBag.NazivKategorije</span>
                    </h2>
                    <a href="@Url.Action("ManageVendors", "Admin")" class="btn-add" style="text-decoration: none; padding: 12px 20px; line-height: normal; height: auto; grid-column: auto; text-align:center;">Prikaži sve</a>
                </div>
            }
            else
            {
                <button class="btn-trigger-form" id="btnToggleForm" onclick="toggleForma()">
                    <svg class="svg-icon btn-icon" viewBox="0 0 24 24" id="btnIcon">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span id="btnText">Kreiraj novog vendora</span>
                </button>
                <div class="glass-panel" id="panelForma" style="display: none; transition: 0.3s;">
                    <h2>
                        <svg class="svg-icon title-icon" viewBox="0 0 24 24">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="12" y1="18" x2="12" y2="12"></line>
                            <line x1="9" y1="15" x2="15" y2="15"></line>
                        </svg>
                        Unos novog vendora
                    </h2>
                    <form action="@Url.Action("DodajVendora", "Admin")" method="post" enctype="multipart/form-data" class="form-inline">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label>Naziv vendora</label>
                            <input type="text" name="naziv" required placeholder="npr. Bend Matrix" />
                        </div>
                        <div class="form-group">
                            <label>Kategorija</label>
                            <select name="kategorijaId" required>
                                @if (kategorije != null)
                                {
                                    foreach (var kat in kategorije)
                                    {
                                        <option value="@kat.Id">@kat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Kontakt</label>
                            <input type="text" name="kontakt" required placeholder="067-123-456" />
                        </div>
                        <div class="form-group">
                            <label>Osnovna cijena (€)</label>
                            <input type="number" name="cijena" step="0.01" required placeholder="0.00" />
                        </div>

                        <div class="form-group" style="grid-column: span 2;">
                            <label>Izaberi sliku (Opciono)</label>
                            <input type="file" name="slikaFajl" accept="image/*" style="background: rgba(255,255,255,0.8); padding: 9px;" />
                        </div>

                        <button type="submit" class="btn-add">
                            <svg class="svg-icon btn-icon" viewBox="0 0 24 24">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                <polyline points="7 3 7 8 15 8"></polyline>
                            </svg>
                            Sačuvaj u bazu
                        </button>
                    </form>
                </div>
            }

            <div class="glass-panel" style="padding: 20px 0;">
                <h2 style="padding: 0 30px;">
                    <svg class="svg-icon title-icon" viewBox="0 0 24 24">
                        <line x1="8" y1="6" x2="21" y2="6"></line>
                        <line x1="8" y1="12" x2="21" y2="12"></line>
                        <line x1="8" y1="18" x2="21" y2="18"></line>
                        <line x1="3" y1="6" x2="3.01" y2="6"></line>
                        <line x1="3" y1="12" x2="3.01" y2="12"></line>
                        <line x1="3" y1="18" x2="3.01" y2="18"></line>
                    </svg>
                    Lista vendora
                </h2>
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th style="padding-left: 30px;">Slika</th>
                            <th>Naziv</th>
                            <th>Kategorija</th>
                            <th>Kontakt</th>
                            <th>Cijena</th>
                            <th>Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var v in Model)
                            {
                                <tr>
                                    <td data-label="Fotografija" style="padding-left: 30px;">
                                        <img src="@v.ImagePath" class="vendor-img" alt="Vendor" />
                                    </td>
                                    <td data-label="Naziv" style="font-weight: 700; font-size: 16px;">@v.Name</td>
                                    <td data-label="Kategorija">
                                        <span class="v-badge" style="margin-bottom:0;">@(v.VendorCategory != null ? v.VendorCategory.CategoryName : "N/A")</span>
                                    </td>
                                    <td data-label="Kontakt" style="font-weight: 500;">@v.Contact</td>
                                    <td data-label="Cijena" style="font-weight: 800; font-size: 16px;">@v.BasePrice €</td>
                                    <td data-label="Akcija">
                                        <div class="action-btns">
                                            <button type="button" class="btn-edit" onclick="otvoriModalEdit(@v.Id, '@v.Name.Replace("'", "\\'")', @v.CategoryID, '@v.Contact.Replace("'", "\\'")', '@v.BasePrice')">Izmijeni</button>
                                            <a href="@Url.Action("ObrisiVendora", "Admin", new { id = v.Id })" class="btn-del" onclick="return confirm('Da li ste sigurni da želite obrisati ovog vendora?');">Obriši</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="editModal">
        <div class="modal-content">
            <button class="close-modal" onclick="zatvoriModalEdit()">×</button>
            <h2 class="modal-title">
                <svg class="svg-icon title-icon" viewBox="0 0 24 24">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Izmijeni podatke
            </h2>
            <form action="@Url.Action("AzurirajVendora", "Admin")" method="post" enctype="multipart/form-data" class="form-inline" style="grid-template-columns: 1fr;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="form-group">
                    <label>Naziv</label>
                    <input type="text" name="naziv" id="editNaziv" required />
                </div>
                <div class="form-group">
                    <label>Kategorija</label>
                    <select name="kategorijaId" id="editKategorija" required>
                        @if (kategorije != null)
                        {
                            foreach (var kat in kategorije)
                            {
                                <option value="@kat.Id">@kat.CategoryName</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Kontakt</label>
                    <input type="text" name="kontakt" id="editKontakt" required />
                </div>
                <div class="form-group">
                    <label>Cijena (€)</label>
                    <input type="number" name="cijena" id="editCijena" step="0.01" required />
                </div>
                <div class="form-group">
                    <label>Promijeni sliku (Opciono)</label>
                    <input type="file" name="slikaFajlUredi" accept="image/*" style="background: rgba(0,0,0,0.05); padding: 9px;" />
                </div>
                <button type="submit" class="btn-submit-modal">
                    <svg class="svg-icon btn-icon" viewBox="0 0 24 24">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                        <polyline points="7 3 7 8 15 8"></polyline>
                    </svg>
                    Sačuvaj promjene
                </button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });

        function toggleForma() {
            var panel = document.getElementById("panelForma");
            var dugme = document.getElementById("btnToggleForm");
            var textSpana = document.getElementById("btnText");
            var ikonicasvg = document.getElementById("btnIcon");

            if (panel.style.display === "none") {
                panel.style.display = "block";
                textSpana.innerHTML = "Zatvori formu";
                ikonicasvg.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                dugme.style.background = "var(--logo-pink)";
            } else {
                panel.style.display = "none";
                textSpana.innerHTML = "Kreiraj novog vendora";
                ikonicasvg.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>';
                dugme.style.background = "var(--logo-green)";
            }
        }

        function otvoriModalEdit(id, naziv, kategorijaId, kontakt, cijenaStr) {
            document.getElementById('editId').value = id;
            document.getElementById('editNaziv').value = naziv;
            document.getElementById('editKategorija').value = kategorijaId;
            document.getElementById('editKontakt').value = kontakt;
            document.getElementById('editCijena').value = parseFloat(cijenaStr.toString().replace(',', '.'));
            document.getElementById('editModal').style.display = 'flex';
        }

        function zatvoriModalEdit() {
            document.getElementById('editModal').style.display = 'none';
        }
    </script>
</body>
</html>