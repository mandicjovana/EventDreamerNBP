@model IEnumerable<EventDreamer.Models.User>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin korisnici - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* za boje */
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        /* za pozadinu */
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-overlay {
            position: absolute;
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(5px);
            z-index: 1;
        }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        .page-title {
            text-align: center;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 30px;
            color: var(--text-dark);
        }

        /* za svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm { 
            width: 16px; 
            height: 16px; 
        }

        .icon-md { 
            width: 20px; 
            height: 20px; 
        }

        .icon-lg { 
            width: 28px; 
            height: 28px; 
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li { 
            margin-bottom: 8px; 
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: var(--text-dark);
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: var(--text-dark);
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* za dugmice da imaju boju sa logoa */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-del {
            background: var(--logo-pink);
            color: #222;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.3s ease;
            display: inline-block;
            text-align: center;
        }

        .btn-del:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
        }

        /* za kartice i liste korisnika */
        .list-container { 
            max-width: 1100px; 
            margin: 0 auto; 
            width: 100%; 
        }

        .list-header {
            display: grid; 
            grid-template-columns: 60px 2fr 2fr 1.5fr 80px; 
            padding: 0 30px; 
            margin-bottom: 15px;
            font-size: 12px; 
            font-weight: 700; 
            color: #555; 
            text-transform: uppercase; 
            letter-spacing: 1px;
        }

        .user-row {
            display: grid; 
            grid-template-columns: 60px 2fr 2fr 1.5fr 80px; 
            align-items: center;
            background: rgba(255, 255, 255, 0.75); 
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.9); 
            padding: 15px 30px; 
            border-radius: 15px; 
            margin-bottom: 15px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03); 
            transition: 0.3s;
        }

        .user-row:hover {
            background: rgba(255, 255, 255, 0.9); 
            transform: translateY(-2px); 
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
        }

        .u-id { 
            color: #888; 
            font-weight: 600; 
        }

        .u-name { 
            font-weight: 700; 
            color: #111; 
            font-size: 16px; 
        }

        .u-email { 
            color: #555; 
            font-weight: 500; 
            font-size: 14px; 
        }

        .role-badge {
            display: inline-flex; 
            align-items: center; 
            gap: 6px;
            padding: 6px 12px; 
            border-radius: 20px; 
            font-size: 12px; 
            font-weight: 700;
        }

        .role-badge.admin { 
            background: var(--logo-pink); 
            color: #222; 
        }

        .role-badge.user { 
            background: var(--logo-green); 
            color: #222; 
        }

        .alert-box {
            padding: 15px 20px; 
            border-radius: 10px; 
            font-weight: 600; 
            margin-bottom: 20px;
            display: flex; 
            align-items: center; 
            gap: 10px;
        }

        .alert-success { 
            background: #d4edda; 
            color: #155724; 
            border: 1px solid #c3e6cb; 
        }

        .alert-error { 
            background: #f8d7da; 
            color: #721c24; 
            border: 1px solid #f5c6cb; 
        }

        .mobile-action-row { 
            display: contents; 
        }

        /* responsive dizajn */
        .mobile-header { 
            display: none; 
        }

        @@media screen and (max-width: 768px) {
            .bg-image { 
                flex-direction: column; 
            }

            .sidebar { 
                width: 100% !important; 
                border-right: none; 
                border-bottom: 1px solid rgba(255, 255, 255, 0.4); 
                padding: 15px 20px; 
            }

            .sidebar .logo-text { 
                display: none; 
            }

            .mobile-header { 
                display: flex; 
                justify-content: flex-start; 
                align-items: center; 
                width: 100%; 
                gap: 15px; 
            }

            .mobile-header .logo-text-mobile { 
                font-size: 20px; 
                font-weight: 800; 
                color: #111; 
                text-transform: uppercase; 
                margin: 0; 
                display: flex; 
                align-items: center; 
                gap: 8px;
            }

            .hamburger-btn { 
                background: none; 
                border: none; 
                font-size: 28px; 
                cursor: pointer; 
                color: #111; 
                padding: 0; 
                display: flex; 
                align-items: center; 
            }

            .sidebar-menu { 
                display: none; 
                flex-direction: column; 
                width: 100%; 
                margin-top: 20px; 
            }

            .sidebar-menu.active { 
                display: flex; 
            }

            .sidebar-menu a { 
                justify-content: center; 
                transform: none !important; 
            }

            .sidebar-menu a:hover:not(.active) { 
                transform: none !important; 
            }

            .logout-btn.desktop-only { 
                display: none; 
            }

            .logout-btn.mobile-only { 
                display: flex; 
                margin-top: 10px; 
            }

            .main-content { 
                padding: 30px 15px; 
            }

            .page-title { 
                font-size: 22px; 
                margin-bottom: 25px; 
            }

            .list-header { 
                display: none; 
            }

            .user-row { 
                display: flex; 
                flex-direction: column; 
                align-items: flex-start; 
                gap: 8px; 
                padding: 20px; 
                position: relative; 
            }

            .u-id { 
                position: absolute; 
                top: 20px; 
                right: 20px; 
                font-size: 14px; 
            }

            .u-name { 
                font-size: 18px; 
                margin-bottom: 5px; 
                width: 80%; 
            }

            .u-email { 
                margin-bottom: 15px; 
                word-break: break-all; 
                font-size: 14px; 
            }

            .mobile-action-row { 
                display: flex; 
                justify-content: space-between; 
                align-items: center; 
                width: 100%; 
                margin-top: 10px; 
                border-top: 1px dashed rgba(0, 0, 0, 0.1); 
                padding-top: 15px; 
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    Admin
                </h2>
            </div>

            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                Admin sistem
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                        </svg> 
                        Statistika
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageUsers", "Admin")" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg> 
                        Svi korisnici
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageVendors", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M3 3h18v4l-1.5 9h-15L3 7z"></path>
                            <line x1="12" y1="16" x2="12" y2="22"></line>
                            <line x1="8" y1="22" x2="16" y2="22"></line>
                        </svg> 
                        Vendori
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ManageEvents", "Admin")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg> 
                        Svi događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Home")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Index", "Home")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            <div class="list-container">
                <div class="page-title">Spisak registrovanih korisnika</div>

                @if (TempData["Poruka"] != null)
                {
                    <div class="alert-box alert-success">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        @TempData["Poruka"]
                    </div>
                }
                
                @if (TempData["Greska"] != null)
                {
                    <div class="alert-box alert-error">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        @TempData["Greska"]
                    </div>
                }

                <div class="list-header">
                    <div>ID</div>
                    <div>IME I PREZIME</div>
                    <div>EMAIL ADRESA</div>
                    <div>ULOGA</div>
                    <div style="text-align:right;">AKCIJA</div>
                </div>

                @if (Model != null)
                {
                    foreach (var u in Model)
                    {
                        bool isAdmin = (u.RoleId == 1);
                        <div class="user-row">
                            <div class="u-id">#@u.Id</div>
                            <div class="u-name">@u.FirstName @u.LastName</div>
                            <div class="u-email">@u.Email</div>
                            <div class="mobile-action-row">
                                <div>
                                    <span class="role-badge @(isAdmin ? "admin" : "user")">
                                        @if (isAdmin)
                                        {
                                            <svg class="svg-icon icon-sm" viewBox="0 0 24 24">
                                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                                            </svg>
                                            <text>Admin</text>
                                        }
                                        else
                                        {
                                            <svg class="svg-icon icon-sm" viewBox="0 0 24 24">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="12" cy="7" r="4"></circle>
                                            </svg>
                                            <text>Korisnik</text>
                                        }
                                    </span>
                                </div>
                                <div style="text-align:right;">
                                    @if (!isAdmin)
                                    {
                                        <a href="@Url.Action("ObrisiKorisnika", "Admin", new { id = u.Id })" class="btn-del" onclick="return confirm('Brisanjem korisnika brišete i sve njegove događaje, troškove i goste. Da li ste sigurni?');">Obriši</a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                // svg ikonica za close
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                // svg za hamburger meni
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>