@model IEnumerable<EventDreamer.Models.Expens>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Budžet i troškovi - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        /* pozadina */
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 1;
        }

        .main-content {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
            position: relative;
            z-index: 10;
        }

        /* svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .title-icon {
            vertical-align: text-bottom;
            margin-right: 8px;
            width: 28px;
            height: 28px;
        }

        .btn-icon {
            margin-right: 6px;
            vertical-align: middle;
            width: 16px;
            height: 16px;
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: var(--text-dark);
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: var(--text-dark);
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* za dugmice */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-add {
            padding: 12px 30px;
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            height: 43px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-add:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-del {
            background: var(--logo-pink);
            color: #222;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.3s ease;
            display: inline-block;
            text-align: center;
        }

        .btn-del:hover {
            background: #e63946;
            color: #fff;
            transform: translateY(-2px);
        }

        /* za panele i stranice*/
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 40px;
            width: 100%;
        }

        .glass-panel h2 {
            margin-top: 0;
            font-weight: 800;
            font-size: 24px;
            color: #111;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
        }

        .event-info-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 25px;
            font-weight: 700;
            font-size: 16px;
            color: #222;
            display: flex;
            align-items: center;
            gap: 15px;
            border-left: 5px solid var(--logo-green);
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            flex-wrap: wrap;
        }

        /* statistika budzeta*/
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            font-weight: 700;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
            font-size: 14px;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-card span {
            display: block;
            font-size: 26px;
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            margin-top: 10px;
            color: #111;
            letter-spacing: -0.5px;
        }

        .stat-card.total span {
            color: #111;
        }

        .stat-card.green span {
            color: #2a9d8f;
        }

        .stat-card.remaining span {
            color: #e63946;
        }

        /* forma */
        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
            cursor: pointer;
        }

        /* tabela za troskove*/
        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .glass-table th, .glass-table td {
            padding: 15px 20px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .glass-table th {
            font-weight: 700;
            color: #555;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* responsive dizajn */
        .mobile-header {
            display: none;
        }

        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

            .sidebar-menu.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .glass-panel {
                padding: 25px 20px;
            }

            .form-inline {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .btn-add {
                width: 100%;
                margin-top: 10px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .glass-table, .glass-table tbody, .glass-table tr, .glass-table td {
                display: block;
                width: 100%;
            }

            .glass-table thead {
                display: none;
            }

            .glass-table tr {
                background: rgba(255, 255, 255, 0.8);
                margin-bottom: 15px;
                border-radius: 15px;
                border: 1px solid rgba(0, 0, 0, 0.1);
                padding: 5px;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            }

            .glass-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-align: right;
                padding: 12px 15px;
                border-bottom: 1px dotted rgba(0, 0, 0, 0.1);
            }

            .glass-table td:last-child {
                border-bottom: none;
                justify-content: center;
                padding-left: 10px;
                margin-top: 5px;
            }

            .glass-table td::before {
                content: attr(data-label);
                font-weight: 800;
                font-size: 11px;
                text-transform: uppercase;
                color: #555;
                text-align: left;
                flex-basis: 40%;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                    </svg>
                    EventDreamer
                </h2>
            </div>

            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
                EventDreamer
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Dashboard")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        Kontrolna tabla
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        Moji događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Tasks")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        Lista zadataka
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Guests")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        Lista gostiju
                    </a>
                </li>
                <li>
                    <a href="#" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        Budžet i troškovi
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Vendors")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                        Pronađi vendore
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            @if (ViewBag.NemaDogadjaja != null && ViewBag.NemaDogadjaja == true)
            {
                <div class="glass-panel" style="text-align: center; padding: 50px 20px;">
                    <h2 style="color: #555; justify-content: center;">
                        <svg class="svg-icon title-icon" viewBox="0 0 24 24" style="color: #e63946;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        Nema kreiranih događaja!
                    </h2>
                    <p style="font-weight: 500;">Da biste upravljali budžetom, prvo morate kreirati makar jedan događaj.</p>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")" class="btn-add" style="display: inline-flex; text-decoration: none; margin-top: 20px; line-height: 20px;">Kreiraj događaj</a>
                </div>
            }
            else
            {
                <div class="event-info-panel">
                    <form action="@Url.Action("Index", "Budget")" method="get" style="margin: 0; width: 100%; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                        <label style="margin: 0; display: flex; align-items: center; gap: 10px;">
                            <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                            Aktivni pregled za:
                        </label>
                        @Html.DropDownList("eventId", (SelectList)ViewBag.EventId, new { onchange = "this.form.submit()", @style = "padding: 8px 15px; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-family: 'Montserrat', sans-serif; font-weight: 700; cursor: pointer; flex: 1; min-width: 200px; background: #fff;" })
                    </form>
                </div>

                <div class="stats-grid">
                    <div class="stat-card total">Predviđeni budžet <span>@ViewBag.Ukupno €</span></div>
                    <div class="stat-card green">Ukupno potrošeno <span>@ViewBag.Potroseno €</span></div>
                    <div class="stat-card remaining">Preostali budžet <span>@ViewBag.Preostalo €</span></div>
                </div>

                <div class="glass-panel">
                    <h2>
                        <svg class="svg-icon title-icon" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        Evidentiraj trošak
                    </h2>
                    <form action="@Url.Action("DodajTrosak", "Budget")" method="post" class="form-inline">
                        <input type="hidden" name="EventId" value="@ViewBag.TrenutniDogadjajId" />
                        <div class="form-group">
                            <label>Naziv stavke / vendora</label>
                            <input type="text" name="naziv" required placeholder="npr. Fotograf, torte, bend" />
                        </div>
                        <div class="form-group">
                            <label>Planirano (€)</label>
                            <input type="number" name="planirano" step="0.01" required placeholder="0.00" />
                        </div>
                        <div class="form-group">
                            <label>Stvarno (€)</label>
                            <input type="number" name="stvarno" step="0.01" required placeholder="0.00" />
                        </div>
                        <div class="form-group">
                            <label>Plaćeno?</label>
                            <select name="placeno">
                                <option value="Ne">Ne</option>
                                <option value="Da">Da</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn-add">
                                <svg class="svg-icon btn-icon" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                                Upiši
                            </button>
                        </div>
                    </form>
                </div>

                <div class="glass-panel" style="padding: 20px 0;">
                    <h2 style="padding: 0 30px;">
                        <svg class="svg-icon title-icon" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                        Detaljna lista
                    </h2>
                    <table class="glass-table">
                        <thead>
                            <tr>
                                <th style="padding-left: 30px;">Naziv stavke</th>
                                <th>Planirani iznos</th>
                                <th>Stvarni iznos</th>
                                <th>Status</th>
                                <th style="text-align: center;">Akcija</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var t in Model)
                                {
                                    <tr>
                                        <td data-label="Naziv stavke" style="padding-left: 30px; font-weight: 600;">@t.ExpenseName</td>
                                        <td data-label="Planirani Iznos" style="font-weight: 500;">@t.PlannedAmount €</td>
                                        <td data-label="Stvarni Iznos" style="font-weight: 700;">@t.ActualAmount €</td>
                                        <td data-label="Status">
                                            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 6px 12px; border-radius: 12px; font-size: 12px; font-weight:700; background: @(t.IsPaid ? "#d4edda" : "#f8d7da"); color: @(t.IsPaid ? "#155724" : "#721c24");">
                                                @if (t.IsPaid)
                                                {
                                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                                }
                                                else
                                                {
                                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                                }
                                                @(t.IsPaid ? "Plaćeno" : "Dugovanje")
                                            </span>
                                        </td>
                                        <td data-label="Akcija" style="text-align: center;">
                                            <a href="@Url.Action("ObrisiTrosak", "Budget", new { id = t.Id, eventId = ViewBag.TrenutniDogadjajId })" class="btn-del">Obriši</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 30px; color: #555; font-weight: 600; display: block; width: 100%;">
                                        Trenutno nema unijetih troškova za ovaj događaj.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>