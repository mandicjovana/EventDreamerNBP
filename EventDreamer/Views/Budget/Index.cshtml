@model IEnumerable<EventDreamer.Models.Expens>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Budžet i Troškovi - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            background: #f4eade;
        }

        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.35)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            min-height: 100%;
            display: flex;
        }

        .sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.3);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
        }

            .sidebar .logo-text {
                font-size: 22px;
                font-weight: 700;
                color: #000;
                margin-bottom: 40px;
                text-transform: uppercase;
            }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .sidebar-menu a {
                display: block;
                padding: 12px 15px;
                color: #000;
                font-weight: 600;
                text-decoration: none;
                border-radius: 10px;
                transition: 0.3s;
                margin-bottom: 10px;
            }

                .sidebar-menu a:hover {
                    background: rgba(255, 255, 255, 0.6);
                }

        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
        }

        .event-info-panel {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 12px;
            padding: 15px 20px;
            margin-bottom: 25px;
            font-weight: 700;
            font-size: 16px;
            color: #222;
            display: flex;
            align-items: center;
            gap: 10px;
            border-left: 5px solid #2a9d8f;
        }

        h2 {
            margin-top: 0;
            font-weight: 700;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255,255,255,0.7);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            font-weight: 700;
            border: 1px solid rgba(255,255,255,0.5);
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        }

            .stat-card span {
                display: block;
                font-size: 26px;
                font-family: 'Arial Black', sans-serif;
                margin-top: 10px;
                color: #222;
            }

            .stat-card.total span {
                color: #000;
            }

            .stat-card.green span {
                color: #2a9d8f;
            }

            .stat-card.remaining span {
                color: #e63946;
            }

        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

            .glass-table th, .glass-table td {
                padding: 15px;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .glass-table th {
                background: rgba(255,255,255,0.4);
                font-weight: 700;
            }

        .btn-del {
            color: #fff;
            background: #ff4d4d;
            padding: 6px 12px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: 0.2s;
        }

            .btn-del:hover {
                background: #cc0000;
            }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)) auto;
            gap: 15px;
            align-items: end;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid rgba(0,0,0,0.15);
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255,255,255,0.7);
            box-sizing: border-box;
        }

        .btn-add {
            padding: 10px 25px;
            background: #000;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            height: 40px;
            transition: 0.2s;
        }

            .btn-add:hover {
                background: #222;
            }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="sidebar">
            <div class="logo-text">EventDreamer</div>
            <ul class="sidebar-menu">
                <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")">🎉 Moji Događaji</a></li>
                <li><a href="@Url.Action("Index", "Guests")">👥 Lista Gostiju</a></li>
                <li><a href="#" style="background: rgba(255, 255, 255, 0.6);">💰 Budžet i Troškovi</a></li>
                <li><a href="@Url.Action("Index", "Vendors")">📸 Pronađi Vendore</a></li>
                <li><a href="@Url.Action("Index", "Home")" style="background: #ffccd5; margin-top: 50px;">Odjavi se</a></li>
            </ul>
        </div>
        <div class="main-content">

            @if (ViewBag.NazivDogadjaja != null)
            {
                <div class="event-info-panel">
                    📊 Aktivni pregled za događaj: <span style="color: #000;">@ViewBag.NazivDogadjaja</span>
                </div>
            }

            <div class="stats-grid">
                <div class="stat-card total">Predviđeni Budžet <span>@ViewBag.Ukupno €</span></div>
                <div class="stat-card green">Ukupno Potrošeno <span>@ViewBag.Potroseno €</span></div>
                <div class="stat-card remaining">Preostali Budžet <span>@ViewBag.Preostalo €</span></div>
            </div>

            <div class="glass-panel">
                <h2>💰 Evidentiraj Trošak (SQL Baza)</h2>
                <form action="@Url.Action("DodajTrosak", "Budget")" method="post" class="form-inline">
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Naziv izdatka</label>
                        <input type="text" name="naziv" required placeholder="npr. Bend" />
                    </div>
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Planirano (€)</label>
                        <input type="number" name="planirano" step="0.01" required placeholder="0.00" />
                    </div>
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Stvarno (€)</label>
                        <input type="number" name="stvarno" step="0.01" required placeholder="0.00" />
                    </div>
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Plaćeno?</label>
                        <select name="placeno">
                            <option value="Ne">Ne</option>
                            <option value="Da">Da</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-add">Upiši</button>
                </form>
            </div>

            <div class="glass-panel">
                <h2>📋 Detaljna Lista</h2>
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th>Naziv stavke</th>
                            <th>Planirani Iznos</th>
                            <th>Stvarni Iznos</th>
                            <th>Status</th>
                            <th>Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td style="font-weight: 600;">@t.ExpenseName</td>
                                    <td>@t.PlannedAmount €</td>
                                    <td>@t.ActualAmount €</td>
                                    <td>
                                        <span style="padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight:700; background: @(t.IsPaid ? "#d4edda" : "#f8d7da"); color: @(t.IsPaid ? "#155724" : "#721c24");">
                                            @(t.IsPaid ? "Plaćeno" : "Dugovanje")
                                        </span>
                                    </td>
                                    <td><a href="@Url.Action("ObrisiTrosak", "Budget", new { id = t.Id })" class="btn-del">Obriši</a></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 20px; color: #666; font-weight: 500;">
                                    Trenutno nema unijetih troškova za ovaj događaj.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>