@model IEnumerable<EventDreamer.Models.Guest>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Lista Gostiju - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            background: #f4eade;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.35)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            width: 100%;
        }

        .sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-right: 1px solid rgba(255, 255, 255, 0.3);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 22px;
            font-weight: 700;
            color: #000;
            margin-bottom: 40px;
            text-transform: uppercase;
            text-align: center;
        }

        .sidebar-nav-container {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar-menu a {
            display: block;
            padding: 12px 15px;
            color: #000;
            font-weight: 600;
            text-decoration: none;
            border-radius: 10px;
            transition: 0.3s;
            margin-bottom: 10px;
        }

        .sidebar-menu a:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            width: 100%;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
            width: 100%;
        }

        h2 {
            margin-top: 0;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .glass-table th, .glass-table td {
            padding: 15px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .glass-table th {
            background: rgba(255,255,255,0.4);
            font-weight: 700;
        }

        .btn-del {
            color: #fff;
            background: #ff4d4d;
            padding: 6px 12px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            display: inline-block;
            transition: 0.3s;
        }

        .btn-del:hover {
            background: #e60000;
        }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            align-items: end;
        }

        .form-inline .btn-container {
            display: flex;
            align-items: flex-end;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid rgba(0,0,0,0.15);
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255,255,255,0.7);
            box-sizing: border-box;
            cursor: pointer;
        }

        .btn-add {
            padding: 10px 25px;
            background: #000;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            height: 40px;
            width: 100%;
            transition: 0.3s;
        }

        .btn-add:hover {
            background: #333;
        }

        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.3);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

           .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 700;
                color: #000;
                text-transform: uppercase;
                margin: 0;
           }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #000;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-nav-container {
                display: none;
                width: 100%;
                margin-top: 20px;
                flex-direction: column;
            }

            .sidebar-nav-container.active {
                display: flex;
            }

            .sidebar-menu a {
                padding: 12px;
                text-align: center;
                font-size: 15px;
                background: rgba(255, 255, 255, 0.4);
            }

            .main-content {
                padding: 20px 15px;
            }

            .glass-panel {
                padding: 20px;
            }

            .form-inline {
                grid-template-columns: 1fr;
            }

            .glass-table, .glass-table tbody, .glass-table tr, .glass-table td {
                display: block;
                width: 100%;
            }

            .glass-table thead {
                display: none;
            }

            .glass-table tr {
                background: rgba(255, 255, 255, 0.6);
                margin-bottom: 15px;
                border-radius: 12px;
                border: 1px solid rgba(0,0,0,0.1);
                padding: 10px;
                box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            }

            .glass-table td {
                text-align: right;
                /* 45% prostora sa lijeve strane za naslov */
                padding: 12px 10px 12px 45%;
                border-bottom: 1px dotted rgba(0,0,0,0.1);
                position: relative;
                min-height: 45px;
                display: flex;
                justify-content: flex-end;
                align-items: center;
                word-break: break-word; /* ako je naslov događaja predugačak, prelazi u novi red */
            }

            .glass-table td:last-child {
                border-bottom: none;
            }

            .glass-table td::before {
                content: attr(data-label);
                position: absolute;
                left: 10px;
                top: 50%;
                transform: translateY(-50%); /* vertikalno centrira naslov */
                width: 40%;
                padding-right: 10px;
                white-space: normal; /* Dozvoljava naslovu da se prelomi ako zatreba */
                text-align: left;
                font-weight: 700;
                color: #555;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">EventDreamer</h2>
            </div>
            <div class="logo-text">EventDreamer</div>
            <div class="sidebar-nav-container" id="navContainer">
                <ul class="sidebar-menu">
                    <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                    <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")">🎉 Moji događaji</a></li>
                    <li><a href="#" style="background: rgba(255, 255, 255, 0.6);">👥 Lista gostiju</a></li>
                    <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i troškovi</a></li>
                    <li><a href="@Url.Action("Index", "Vendors")">📸 Pronađi vendore</a></li>
                    <li><a href="@Url.Action("Logout", "Account")" style="background: #ffccd5; margin-top: 30px;">Odjavi se</a></li>
                </ul>
            </div>
        </div>

        <div class="main-content">

            <div class="glass-panel">
                <h2>👥 Brzi unos gosta</h2>
                <form action="@Url.Action("DodajGosta", "Guests")" method="post" class="form-inline">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Događaj</label>
                        @Html.DropDownList("EventId", (SelectList)ViewBag.ListaDogadjaja, "-- Izaberite događaj --", new { @required = "required", @style = "width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.15); border-radius: 8px; font-family: 'Montserrat', sans-serif; background: rgba(255,255,255,0.7);" })
                    </div>
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Ime</label>
                        <input type="text" name="ime" required placeholder="npr. Ivan" />
                    </div>
                    <div class="form-group">
                        <label style="font-size: 13px; font-weight: 600; display:block; margin-bottom:5px;">Prezime</label>
                        <input type="text" name="prezime" required placeholder="npr. Ivić" />
                    </div>
                    <div class="form-group btn-container">
                        <button type="submit" class="btn-add">Dodaj</button>
                    </div>
                </form>
            </div>

            <div class="glass-panel">
                <h2>Lista gostiju</h2>
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th>Ime i prezime</th>
                            <th>Status dolaska</th>
                            <th>Dodijeljeni sto</th>
                            <th>Događaj</th>
                            <th>Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var g in Model)
                            {
                                <tr>
                                    <td data-label="Ime i Prezime" style="font-weight: 600;">@g.FirstName @g.LastName</td>

                                    <td data-label="Status dolaska">
                                        <form id="formaStatus-@g.Id" action="@Url.Action("AzurirajStatus", "Guests")" method="post" style="margin: 0; width: 100%; text-align: left;">
                                            <input type="hidden" name="id" value="@g.Id" />
                                            <input type="hidden" name="brojStola" id="sto-@g.Id" value="" />

                                            @{
                                                // za ciscenje razmaka
                                                string status = g.RSVPStatus != null ? g.RSVPStatus.Trim() : "";
                                                bool isPotvrdjeno = status.Contains("Potvr");
                                                bool isOtkazano = status.Contains("Otkaza");
                                                // Ako nije ni potvrđeno ni otkazano, sistem će znati da je Na čekanju
                                            }

                                            <select name="noviStatus" onchange="provjeriStatus(this, @g.Id)"
                                                    style="padding: 6px 12px; border-radius: 12px; font-size: 12px; font-weight:700; border: none; cursor: pointer; outline: none; font-family: 'Montserrat', sans-serif;
                                                    background: @(isPotvrdjeno ? "#d4edda" : (isOtkazano ? "#f8d7da" : "#fff3cd"));
                                                    color: @(isPotvrdjeno ? "#155724" : (isOtkazano ? "#721c24" : "#856404"));">

                                                <option value="Potvrđeno" @(isPotvrdjeno ? "selected" : "")>Potvrđeno</option>
                                                <option value="Na čekanju" @(!isPotvrdjeno && !isOtkazano ? "selected" : "")>Na čekanju</option>
                                                <option value="Otkazano" @(isOtkazano ? "selected" : "")>Otkazano</option>

                                            </select>
                                        </form>
                                    </td>

                                    <td data-label="Dodijeljeni sto">
                                        @(g.TableNumber == null || g.TableNumber == 0 ? "Nema stola" : $"Sto broj {g.TableNumber}")
                                    </td>
                                    <td data-label="Događaj">@(g.Event != null ? g.Event.Title : "Nepoznato")</td>
                                    <td data-label="Akcija">
                                        <a href="@Url.Action("ObrisiGosta", "Guests", new { id = g.Id })" class="btn-del">Ukloni</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; font-weight: 600; color: #555; display: block; width: 100%;">Nemate kreiranih gostiju. Popunite formu iznad!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Hamburger Meni
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            if (nav.classList.contains("active")) {
                this.innerHTML = "✕";
            } else {
                this.innerHTML = "☰";
            }
        });

        // za status stola
        function provjeriStatus(selectElement, gostId) {
            var forma = document.getElementById("formaStatus-" + gostId);
            var stoInput = document.getElementById("sto-" + gostId);

            if (selectElement.value === "Potvrđeno") {
                var unijetiSto = prompt("Gost je potvrdio dolazak! Unesite broj stola za ovog gosta:");

                if (unijetiSto !== null && unijetiSto.trim() !== "") {
                    stoInput.value = unijetiSto;
                    forma.submit();
                } else {
                    window.location.reload();
                }
            } else {
                stoInput.value = "";
                forma.submit();
            }
        }
    </script>
</body>
</html>