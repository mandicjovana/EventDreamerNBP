@model IEnumerable<EventDreamer.Models.Task>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Zadaci i Obaveze - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        /* pozadina */
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 1;
        }

        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        /* svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .title-icon {
            vertical-align: text-bottom;
            margin-right: 8px;
            width: 28px;
            height: 28px;
        }

        .btn-icon {
            margin-right: 6px;
            vertical-align: middle;
            width: 16px;
            height: 16px;
        }

        /* sidebar*/
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-nav-container {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: #111;
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: #111;
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* dugmici u logo bojama */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-add {
            width: 100%;
            height: 44px;
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn-add:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-del {
            background: var(--logo-pink);
            color: #222;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        .btn-del:hover {
            background: #e63946;
            color: #fff;
            transform: translateY(-2px);
        }

        /* paneli i forme */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
        }

        .glass-panel h2 {
            display: flex;
            align-items: center;
            margin-top: 0;
            font-weight: 800;
            font-size: 24px;
            color: #111;
            margin-bottom: 25px;
        }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
            cursor: pointer;
            outline: none;
        }

        .form-group input:focus, .form-group select:focus {
            border-color: var(--logo-green);
            background: #fff;
        }

        /* tabela sa zadacima */
        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .glass-table th, .glass-table td {
            padding: 15px 20px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .glass-table th {
            font-weight: 700;
            color: #555;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .status-btn {
            padding: 6px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: 0.3s;
        }

        .status-btn:hover {
            transform: scale(1.05);
        }

        /* responsive dizajn */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-nav-container {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

            .sidebar-nav-container.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
                transform: none !important;
            }

            .sidebar-menu a:hover:not(.active) {
                transform: none !important;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .form-inline {
                grid-template-columns: 1fr;
            }

            .glass-table, .glass-table tbody, .glass-table tr, .glass-table td {
                display: block;
                width: 100%;
            }

            .glass-table thead {
                display: none;
            }

            .glass-table tr {
                background: rgba(255, 255, 255, 0.8);
                margin-bottom: 15px;
                border-radius: 15px;
                border: 1px solid rgba(0, 0, 0, 0.1);
                padding: 5px;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            }

            .glass-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-align: right;
                padding: 12px 15px;
                border-bottom: 1px dotted rgba(0, 0, 0, 0.1);
            }

            .glass-table td:last-child {
                border-bottom: none;
                justify-content: center;
                margin-top: 5px;
            }

            .glass-table td::before {
                content: attr(data-label);
                font-weight: 800;
                font-size: 11px;
                text-transform: uppercase;
                color: #555;
                text-align: left;
                flex-basis: 40%;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>
                    EventDreamer
                </h2>
            </div>
            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>
                EventDreamer
            </div>
            <div class="sidebar-nav-container" id="navContainer">
                <ul class="sidebar-menu">
                    <li><a href="@Url.Action("Index", "Dashboard")"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg> Kontrolna tabla</a></li>
                    <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg> Moji događaji</a></li>
                    <li><a href="#" class="active"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg> Lista zadataka</a></li>
                    <li><a href="@Url.Action("Index", "Guests")"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg> Lista gostiju</a></li>
                    <li><a href="@Url.Action("Index", "Budget")"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg> Budžet i troškovi</a></li>
                    <li><a href="@Url.Action("Index", "Vendors")"><svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg> Pronađi vendore</a></li>
                    <li><a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a></li>
                </ul>
                <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                    Odjavi se
                </a>
            </div>
        </div>

        <div class="main-content">

            @if (TempData["Greska"] != null)
            {
                <div style="background: #fdf2f1; color: #c5221f; padding: 15px 20px; border-radius: 12px; font-weight: 700; margin-bottom: 25px; border: 1px solid #fce8e6; display:flex; align-items:center; gap:10px;">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    @TempData["Greska"]
                </div>
            }

            <div class="glass-panel">
                <h2>
                    <svg class="svg-icon title-icon" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    Brzi unos zadatka
                </h2>
                <form action="@Url.Action("DodajZadatak", "Tasks")" method="post" class="form-inline">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label>Događaj</label>
                        @Html.DropDownList("EventId", (SelectList)ViewBag.ListaDogadjaja, "-- Izaberite događaj --", new { @required = "required" })
                    </div>

                    <div class="form-group">
                        <label>Naziv obaveze / zadatka</label>
                        <input type="text" name="taskName" required placeholder="npr. Kupiti burme, torta..." />
                    </div>

                    <div class="form-group">
                        <label>Rok za završetak</label>
                        <input type="date" name="dueDate" />
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn-add">
                            <svg class="svg-icon btn-icon" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            Dodaj zadatak
                        </button>
                    </div>
                </form>
            </div>

            <div class="glass-panel" style="padding: 20px 0;">
                <h2 style="padding: 0 30px;">
                    <svg class="svg-icon title-icon" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                    Lista preostalih obaveza
                </h2>
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th style="padding-left: 30px;">Naziv zadatka</th>
                            <th>Događaj</th>
                            <th>Rok za završetak</th>
                            <th>Status obaveze</th>
                            <th style="text-align: center;">Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td data-label="Naziv zadatka" style="padding-left: 30px; font-weight: 600; @(t.IsCompleted ? "text-decoration: line-through; color: #888;" : "")">
                                        @t.TaskName
                                    </td>

                                    <td data-label="Događaj" style="font-weight: 500;">@(t.Event != null ? t.Event.Title : "Nepoznato")</td>

                                    <td data-label="Rok" style="font-weight: 600; color: #444;">
                                        @(t.DueDate.HasValue ? t.DueDate.Value.ToString("dd.MM.yyyy") : "Nema roka")
                                    </td>

                                    <td data-label="Status obaveze">
                                        <form action="@Url.Action("PromijeniStatus", "Tasks")" method="post" style="margin:0;">
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button type="submit" class="status-btn" style="background: @(t.IsCompleted ? "#d4edda" : "#fff3cd"); color: @(t.IsCompleted ? "#155724" : "#856404");">
                                                @if (t.IsCompleted)
                                                {
                                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                                    <span>Završeno</span>
                                                }
                                                else
                                                {
                                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                                    <span>U toku</span>
                                                }
                                            </button>
                                        </form>
                                    </td>

                                    <td data-label="Akcija" style="text-align: center;">
                                        <a href="@Url.Action("ObrisiZadatak", "Tasks", new { id = t.Id })" class="btn-del">
                                            <svg class="svg-icon btn-icon" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                            Ukloni
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 30px; font-weight: 600; color: #555; display: block; width: 100%;">
                                    <svg class="svg-icon icon-lg" viewBox="0 0 24 24" style="margin-bottom: 10px; color: #888;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg><br />
                                    Nemate unijetih zadataka. Kreirajte obavezu iznad!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>