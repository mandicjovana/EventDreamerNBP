@model IEnumerable<EventDreamer.Models.Task>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Zadaci i Obaveze - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 1;
        }

        /* PREMIUM SIDEBAR */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 260px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: block;
        }

        .sidebar-nav-container {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 8px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 18px;
                color: #444;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: all 0.3s ease;
                font-size: 14px;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.9);
                    color: #111;
                    transform: translateX(4px);
                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
                }

                .sidebar-menu a.active {
                    background: #111;
                    color: #fff;
                    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
                    transform: translateX(4px);
                }

        /* DUGME ZA ODJAVU */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .logout-btn:hover {
                background: var(--logo-green);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        /* MAIN CONTENT */
        .main-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 30px;
        }

            .glass-panel h2 {
                margin-top: 0;
                font-weight: 800;
                font-size: 24px;
                color: #111;
                margin-bottom: 25px;
            }

        /* FORMA I INPUT POLJA */
        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
            cursor: pointer;
        }

            .form-group input:focus, .form-group select:focus {
                outline: none;
                border-color: var(--logo-green);
                background: #fff;
            }

        /* INTERFEJSNA DUGMAD */
        .btn-add {
            width: 100%;
            height: 44px;
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .btn-add:hover {
                background: var(--logo-pink);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        .btn-del {
            background: var(--logo-pink);
            color: #222;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.3s ease;
            display: inline-block;
            text-align: center;
        }

            .btn-del:hover {
                background: #e63946;
                color: #fff;
                transform: translateY(-2px);
            }

        /* STRUKTURA TABELE */
        .glass-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

            .glass-table th, .glass-table td {
                padding: 15px 20px;
                border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            }

            .glass-table th {
                font-weight: 700;
                color: #555;
                font-size: 13px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        /* 📱 RESPONSIVE (Mobilni uređaji) */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

                .sidebar .logo-text {
                    display: none;
                }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

                .mobile-header .logo-text-mobile {
                    font-size: 20px;
                    font-weight: 800;
                    color: #111;
                    text-transform: uppercase;
                    margin: 0;
                }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-nav-container {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

                .sidebar-nav-container.active {
                    display: flex;
                }

            .sidebar-menu a {
                justify-content: center;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .form-inline {
                grid-template-columns: 1fr;
            }

            .glass-table, .glass-table tbody, .glass-table tr, .glass-table td {
                display: block;
                width: 100%;
            }

                .glass-table thead {
                    display: none;
                }

                .glass-table tr {
                    background: rgba(255, 255, 255, 0.8);
                    margin-bottom: 15px;
                    border-radius: 15px;
                    border: 1px solid rgba(0, 0, 0, 0.1);
                    padding: 5px;
                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
                }

                .glass-table td {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    text-align: right;
                    padding: 12px 15px;
                    border-bottom: 1px dotted rgba(0, 0, 0, 0.1);
                }

                    .glass-table td:last-child {
                        border-bottom: none;
                        justify-content: center;
                        margin-top: 5px;
                    }

                    .glass-table td::before {
                        content: attr(data-label);
                        font-weight: 800;
                        font-size: 11px;
                        text-transform: uppercase;
                        color: #555;
                        text-align: left;
                        flex-basis: 40%;
                    }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">EventDreamer</h2>
            </div>
            <div class="logo-text">EventDreamer</div>
            <div class="sidebar-nav-container" id="navContainer">
                <ul class="sidebar-menu">
                    <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                    <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")">🎉 Moji događaji</a></li>
                    <li><a href="#" class="active">📝 Lista zadataka</a></li>
                    <li><a href="@Url.Action("Index", "Guests")">👥 Lista gostiju</a></li>
                    <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i troškovi</a></li>
                    <li><a href="@Url.Action("Index", "Vendors")">📸 Pronađi vendore</a></li>
                    <li><a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a></li>
                </ul>
                <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">Odjavi se</a>
            </div>
        </div>

        <div class="main-content">

            <div class="glass-panel">
                <h2>📝 Brzi unos zadatka</h2>
                <form action="@Url.Action("DodajZadatak", "Tasks")" method="post" class="form-inline">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label>Događaj</label>
                        @Html.DropDownList("EventId", (SelectList)ViewBag.ListaDogadjaja, "-- Izaberite događaj --", new { @required = "required" })
                    </div>

                    <div class="form-group">
                        <label>Naziv obaveze / zadatka</label>
                        <input type="text" name="taskName" required placeholder="npr. Kupiti burme, rezervisati tortu..." />
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn-add">Dodaj zadatak</button>
                    </div>
                </form>
            </div>

            <div class="glass-panel" style="padding: 20px 0;">
                <h2 style="padding: 0 30px;">Lista preostalih obaveza</h2>
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th style="padding-left: 30px;">Naziv zadatka</th>
                            <th>Status obaveze</th>
                            <th>Događaj</th>
                            <th style="text-align: center;">Akcija</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td data-label="Naziv zadatka" style="padding-left: 30px; font-weight: 600; @(t.IsCompleted ? "text-decoration: line-through; color: #888;" : "")">
                                        @t.TaskName
                                    </td>

                                    <td data-label="Status obaveze">
                                        <form action="@Url.Action("PromijeniStatus", "Tasks")" method="post" style="margin:0;">
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button type="submit" style="padding: 6px 12px; border-radius: 12px; font-size: 12px; font-weight:700; border: none; cursor: pointer; background: @(t.IsCompleted ? "#d4edda" : "#fff3cd"); color: @(t.IsCompleted ? "#155724" : "#856404");">
                                                @(t.IsCompleted ? "✅ Završeno" : "⏳ U toku")
                                            </button>
                                        </form>
                                    </td>

                                    <td data-label="Događaj" style="font-weight: 500;">@(t.Event != null ? t.Event.Title : "Nepoznato")</td>

                                    <td data-label="Akcija" style="text-align: center;">
                                        <a href="@Url.Action("ObrisiZadatak", "Tasks", new { id = t.Id })" class="btn-del">Ukloni</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 30px; font-weight: 600; color: #555; display: block; width: 100%;">Nemate unijetih zadataka. Kreirajte obavezu iznad!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
        });</script>
</body>
</html>