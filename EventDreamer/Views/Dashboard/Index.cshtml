@{
    ViewBag.Title = "Korisnički Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dashboard - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.5)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            width: 100%;
        }

        /* SIDEBAR */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: block;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 8px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 18px;
                color: #444;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: all 0.3s ease;
                font-size: 14px;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.9);
                    color: #111;
                    transform: translateX(4px);
                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
                }

                .sidebar-menu a.active {
                    background: #111;
                    color: #fff;
                    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
                    transform: translateX(4px);
                }

        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .logout-btn:hover {
                background: var(--logo-green);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
            position: relative;
            z-index: 10;
        }

        .welcome-header {
            margin-bottom: 40px;
            text-align: center;
        }

            .welcome-header h1 {
                font-size: 32px;
                font-weight: 800;
                color: #111;
                margin: 0 0 10px 0;
            }

            .welcome-header p {
                font-weight: 500;
                color: #444;
                font-size: 16px;
            }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
            width: 100%;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

            .glass-card:hover {
                transform: translateY(-5px);
                background: rgba(255, 255, 255, 0.9);
                box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            }

        .card-icon {
            font-size: 35px;
            margin-bottom: 15px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 800;
            color: #111;
            margin-bottom: 10px;
        }

        .card-desc {
            font-size: 14px;
            color: #444;
            font-weight: 500;
            line-height: 1.5;
            margin-bottom: 25px;
            flex-grow: 1;
        }

        .btn-action {
            display: block;
            text-align: center;
            padding: 12px 20px;
            background: var(--logo-green);
            color: #222;
            font-weight: 700;
            text-decoration: none;
            border-radius: 12px;
            font-size: 14px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .btn-action:hover {
                background: var(--logo-pink);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            }

        /* RESPONSIVE */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

                .sidebar .logo-text {
                    display: none;
                }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

                .mobile-header .logo-text-mobile {
                    font-size: 20px;
                    font-weight: 800;
                    color: #111;
                    text-transform: uppercase;
                    margin: 0;
                }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

                .sidebar-menu.active {
                    display: flex;
                }

                .sidebar-menu a {
                    justify-content: center;
                    transform: none !important;
                }

                    .sidebar-menu a:hover:not(.active) {
                        transform: none !important;
                    }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .welcome-header h1 {
                font-size: 24px;
            }

            .card-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">EventDreamer</h2>
            </div>
            <div class="logo-text">EventDreamer</div>
            <ul class="sidebar-menu" id="navContainer">
                <li><a href="@Url.Action("Index", "Dashboard")" class="active">🏠 Kontrolna tabla</a></li>
                <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")">🎉 Moji događaji</a></li>
                <li><a href="@Url.Action("Index", "Tasks")">📝 Lista zadataka</a></li>
                <li><a href="@Url.Action("Index", "Guests")">👥 Lista gostiju</a></li>
                <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i troškovi</a></li>
                <li><a href="@Url.Action("Index", "Vendors")">📸 Pronađi vendore</a></li>
                <li><a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a></li>
            </ul>
            <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">Odjavi se</a>
        </div>

        <div class="main-content">
            <div class="welcome-header">
                <h1>Dobrodošli nazad, @(Session["UserFirstName"] ?? "Korisniče")! ✨</h1>
                <p>Sve što Vam je potrebno za organizaciju savršenog događaja nalazi se na jednom mjestu.</p>
            </div>

            <div class="card-grid">
                <div class="glass-card">
                    <div class="card-icon">📅</div>
                    <div class="card-title">Moji događaji</div>
                    <div class="card-desc">Kreirajte i upravljajte detaljima Vašeg vjenčanja, rođendana ili proslave.</div>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")" class="btn-action">Upravljaj događajima</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">📝</div>
                    <div class="card-title">Lista zadataka</div>
                    <div class="card-desc">Kreirajte To-Do liste, pratite svoje obaveze i označavajte završene zadatke.</div>
                    <a href="@Url.Action("Index", "Tasks")" class="btn-action">Moje obaveze</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">👥</div>
                    <div class="card-title">Lista gostiju</div>
                    <div class="card-desc">Ubacite goste, pratite ko je potvrdio dolazak i rasporedite ih po stolovima.</div>
                    <a href="@Url.Action("Index", "Guests")" class="btn-action">Pregledaj goste</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">💰</div>
                    <div class="card-title">Budžet i troškovi</div>
                    <div class="card-desc">Pratite troškove, unosite uplate i koristite kalkulator za preostali budžet.</div>
                    <a href="@Url.Action("Index", "Budget")" class="btn-action">Izračunaj budžet</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">🔍</div>
                    <div class="card-title">Pretraga vendora</div>
                    <div class="card-desc">Pretražite fotografe, restorane i dekoraciju po lokaciji, kategoriji i cijeni.</div>
                    <a href="@Url.Action("Index", "Vendors")" class="btn-action">Pretraži ponudu</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            if (nav.classList.contains("active")) {
                this.innerHTML = "✕";
                mobileLogout.style.display = "flex";
            } else {
                this.innerHTML = "☰";
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>