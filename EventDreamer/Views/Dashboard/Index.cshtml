@{
    ViewBag.Title = "Korisnički Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dashboard - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }
        /*pozadina*/
        .bg-image {
            background-image: linear-gradient(rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.5)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            width: 100%;
        }

        .main-content {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
            position: relative;
            z-index: 10;
        }

        /*svg ikonice*/
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .card-icon svg {
            width: 35px;
            height: 35px;
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: var(--text-dark);
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: var(--text-dark);
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* dugmici */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-action {
            display: block;
            text-align: center;
            padding: 12px 20px;
            background: var(--logo-green);
            color: #222;
            font-weight: 700;
            text-decoration: none;
            border-radius: 12px;
            font-size: 14px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-action:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        /* dashboard kartice */
        .welcome-header {
            margin-bottom: 40px;
            text-align: center;
        }

        .welcome-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #111;
            margin: 0 0 10px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .welcome-header p {
            font-weight: 500;
            color: #444;
            font-size: 16px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
            width: 100%;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        .card-icon {
            margin-bottom: 15px;
            color: #555;
        }

        .card-title {
            font-size: 18px;
            font-weight: 800;
            color: #111;
            margin-bottom: 10px;
        }

        .card-desc {
            font-size: 14px;
            color: #444;
            font-weight: 500;
            line-height: 1.5;
            margin-bottom: 25px;
            flex-grow: 1;
        }

        /* responsive dizajn */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

            .sidebar-menu.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
                transform: none !important;
            }

            .sidebar-menu a:hover:not(.active) {
                transform: none !important;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .welcome-header h1 {
                font-size: 24px;
            }

            .card-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                    </svg>
                    EventDreamer
                </h2>
            </div>
            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
                EventDreamer
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Dashboard")" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        Kontrolna tabla
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        Moji događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Tasks")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        Lista zadataka
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Guests")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        Lista gostiju
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Budget")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        Budžet i troškovi
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Vendors")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                        Pronađi vendore
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            <div class="welcome-header">
                <h1>
                    Dobrodošli nazad, @(Session["UserFirstName"] ?? "Korisniče")!
                    <svg class="svg-icon icon-lg" viewBox="0 0 24 24" style="color: var(--logo-green); fill: currentColor; stroke: none;">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                </h1>
                <p>Sve što Vam je potrebno za organizaciju savršenog događaja nalazi se na jednom mjestu.</p>
            </div>

            <div class="card-grid">
                <div class="glass-card">
                    <div class="card-icon">
                        <svg class="svg-icon" viewBox="0 0 24 24">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </div>
                    <div class="card-title">Moji događaji</div>
                    <div class="card-desc">Kreirajte i upravljajte detaljima Vašeg vjenčanja, rođendana ili proslave.</div>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")" class="btn-action">Upravljaj događajima</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">
                        <svg class="svg-icon" viewBox="0 0 24 24">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                    <div class="card-title">Lista zadataka</div>
                    <div class="card-desc">Kreirajte To-Do liste, pratite svoje obaveze i označavajte završene zadatke.</div>
                    <a href="@Url.Action("Index", "Tasks")" class="btn-action">Moje obaveze</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">
                        <svg class="svg-icon" viewBox="0 0 24 24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="card-title">Lista gostiju</div>
                    <div class="card-desc">Ubacite goste, pratite ko je potvrdio dolazak i rasporedite ih po stolovima.</div>
                    <a href="@Url.Action("Index", "Guests")" class="btn-action">Pregledaj goste</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">
                        <svg class="svg-icon" viewBox="0 0 24 24">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                    </div>
                    <div class="card-title">Budžet i troškovi</div>
                    <div class="card-desc">Pratite troškove, unosite uplate i koristite kalkulator za preostali budžet.</div>
                    <a href="@Url.Action("Index", "Budget")" class="btn-action">Izračunaj budžet</a>
                </div>

                <div class="glass-card">
                    <div class="card-icon">
                        <svg class="svg-icon" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </div>
                    <div class="card-title">Pretraga vendora</div>
                    <div class="card-desc">Pretražite fotografe, restorane i dekoraciju po lokaciji, kategoriji i cijeni.</div>
                    <a href="@Url.Action("Index", "Vendors")" class="btn-action">Pretraži ponudu</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>