@model IEnumerable<EventDreamer.Models.Event>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Moji događaji - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 1;
        }

        /* SIDEBAR */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: block;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

            .sidebar-menu li {
                margin-bottom: 8px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 18px;
                color: #444;
                font-weight: 600;
                text-decoration: none;
                border-radius: 12px;
                transition: all 0.3s ease;
                font-size: 14px;
            }

                .sidebar-menu a:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.9);
                    color: #111;
                    transform: translateX(4px);
                    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
                }

                .sidebar-menu a.active {
                    background: #111;
                    color: #fff;
                    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
                    transform: translateX(4px);
                }

        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .logout-btn:hover {
                background: var(--logo-green);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
            position: relative;
            z-index: 10;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 40px;
            width: 100%;
        }

            .glass-panel h2 {
                margin-top: 0;
                font-weight: 800;
                font-size: 24px;
                color: #111;
                margin-bottom: 25px;
            }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)) auto;
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-add {
            padding: 12px 30px;
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            height: 43px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .btn-add:hover {
                background: var(--logo-pink);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            }

        /* EVENT KARTICE */
        .event-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            width: 100%;
        }

        .event-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

            .event-card:hover {
                transform: translateY(-5px);
                background: rgba(255, 255, 255, 0.9);
                box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            }

            .event-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 6px;
                background: linear-gradient(90deg, var(--logo-pink), var(--logo-green));
            }

        .e-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 15px 0;
            color: #111;
        }

        .e-detail {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 600;
            color: #444;
            margin-bottom: 12px;
        }

        .e-icon {
            background: #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
            font-size: 12px;
        }

        .e-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: auto;
            padding-top: 20px;
        }

        .btn-delete {
            padding: 12px 25px; 
            display: inline-flex;
            align-items: center; 
            justify-content: center; 
            background: var(--logo-pink);
            color: #fff;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            transition: 0.3s;
            font-size: 14px; 
            text-transform: uppercase; 
            letter-spacing: 0.5px;
            border: none;
            cursor: pointer;
        }

            .btn-delete:hover {
                background: var(--logo-green);
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(230, 57, 70, 0.3);
            }
        /* RESPONSIVE */
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

                .sidebar .logo-text {
                    display: none;
                }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

                .mobile-header .logo-text-mobile {
                    font-size: 20px;
                    font-weight: 800;
                    color: #111;
                    text-transform: uppercase;
                    margin: 0;
                }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

                .sidebar-menu.active {
                    display: flex;
                }

                .sidebar-menu a {
                    justify-content: center;
                }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .glass-panel {
                padding: 25px 20px;
            }

            .form-inline {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .btn-add {
                width: 100%;
                margin-top: 10px;
            }

            .event-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">☰</button>
                <h2 class="logo-text-mobile">EventDreamer</h2>
            </div>
            <div class="logo-text">EventDreamer</div>
            <ul class="sidebar-menu" id="navContainer">
                <li><a href="@Url.Action("Index", "Dashboard")">🏠 Kontrolna tabla</a></li>
                <li><a href="@Url.Action("MojiDogadjaji", "Dashboard")" class="active">🎉 Moji događaji</a></li>
                <li><a href="@Url.Action("Index", "Tasks")">📝 Lista zadataka</a></li>
                <li><a href="@Url.Action("Index", "Guests")">👥 Lista gostiju</a></li>
                <li><a href="@Url.Action("Index", "Budget")">💰 Budžet i troškovi</a></li>
                <li><a href="@Url.Action("Index", "Vendors")">📸 Pronađi vendore</a></li>
                <li><a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a></li>
            </ul>
            <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">Odjavi se</a>
        </div>

        <div class="main-content">
            <div class="glass-panel">
                <h2>🎉 Kreiraj novi događaj</h2>
                <form action="@Url.Action("DodajDogadjaj", "Dashboard")" method="post" class="form-inline">
                    <div class="form-group">
                        <label>Naziv događaja</label>
                        <input type="text" name="title" required placeholder="npr. Vjenčanje Ane i Ivana" />
                    </div>
                    <div class="form-group">
                        <label>Datum</label>
                        <input type="date" name="date" required />
                    </div>
                    <div class="form-group">
                        <label>Lokacija (Restoran/Sala)</label>
                        <select name="location" required>
                            <option value=""> Odaberite restoran/salu </option>
                            @if (ViewBag.ListaLokacija != null)
                            {
                                foreach (var selectListItem in (SelectList)ViewBag.ListaLokacija)
                                {
                                    <option value="@selectListItem.Value">@selectListItem.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Ukupan budžet (€)</label>
                        <input type="number" name="totalBudget" step="0.01" required placeholder="0.00" />
                    </div>
                    <button type="submit" class="btn-add">➕ Dodaj</button>
                </form>
            </div>

            <div class="event-grid">
                @if (Model != null && Model.Any())
                {
                    foreach (var e in Model)
                    {
                        <div class="event-card">
                            <h3 class="e-title">@e.Title</h3>

                            <div class="e-detail">
                                <span class="e-icon">📅</span>
                                <span>@(e.Date.HasValue ? e.Date.Value.ToString("dd.MM.yyyy") : "Datum nije određen")</span>
                            </div>

                            <div class="e-detail">
                                <span class="e-icon">📍</span>
                                <span>@(string.IsNullOrEmpty(e.Location) ? "Lokacija na čekanju" : e.Location)</span>
                            </div>

                            <div class="e-detail">
                                <span class="e-icon">💰</span>
                                <span>Budžet: <strong>@e.TotalBudget €</strong></span>
                            </div>

                            <div class="e-detail" style="margin-top: 5px; color: #1e6091;">
                                <span class="e-icon" style="background: #e2eafc; color: #111;">📝</span>
                                <span>
                                    Ukupno zadataka:
                                    <strong>
                                        @if (ViewBag.BrojZadataka != null && ((Dictionary<int, int>)ViewBag.BrojZadataka).ContainsKey(e.Id))
                                        {
                                            @(((Dictionary<int, int>)ViewBag.BrojZadataka)[e.Id])
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </strong>
                                </span>
                            </div>

                            <div class="e-detail" style="margin-top: 5px; color: #2e7d32;">
                                <span class="e-icon" style="background: var(--logo-green); color: #111;">✔️</span>
                                <span>
                                    Potvrđenih gostiju:
                                    <strong>
                                        @if (ViewBag.PotvrdjeniGosti != null && ((Dictionary<int, int>)ViewBag.PotvrdjeniGosti).ContainsKey(e.Id))
                                        {
                                            @(((Dictionary<int, int>)ViewBag.PotvrdjeniGosti)[e.Id])
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </strong>
                                </span>
                            </div>

                            <div class="e-actions">
                                <a href="@Url.Action("ObrisiDogadjaj", "Dashboard", new { id = e.Id })" class="btn-delete" title="Obriši događaj" onclick="return confirm('PAŽNJA! Brisanjem ovog događaja trajno ćete obrisati sve njegove goste, zadatke i cjelokupan budžet. Da li ste sigurni?');">Obriši događaj</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; background: rgba(255,255,255,0.6); border-radius: 20px; font-weight: 600; color: #333; border: 1px dashed rgba(0,0,0,0.2);">
                        Još uvijek niste kreirali nijedan događaj. Ispunite formu iznad da počnete! 🎈
                    </div>
                }
            </div>

        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            if (nav.classList.contains("active")) {
                this.innerHTML = "✕";
                mobileLogout.style.display = "flex";
            } else {
                this.innerHTML = "☰";
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>