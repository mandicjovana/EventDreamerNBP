@model IEnumerable<EventDreamer.Models.Event>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Moji događaji - EventDreamer</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
            --text-dark: #111;
            --text-muted: #555;
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        /* pozadina */ 
        .bg-image {
            background-image: url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            position: relative;
            width: 100%;
        }

        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 1;
        }

        .main-content {
            flex: 1;
            padding: 50px;
            overflow-y: auto;
            width: 100%;
            position: relative;
            z-index: 10;
        }

        /* svg ikonice */
        .svg-icon {
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            display: inline-block;
        }

        .icon-sm {
            width: 16px;
            height: 16px;
        }

        .icon-md {
            width: 20px;
            height: 20px;
        }

        .icon-lg {
            width: 28px;
            height: 28px;
        }

        .title-icon {
            vertical-align: text-bottom;
            margin-right: 8px;
            width: 28px;
            height: 28px;
        }

        .btn-icon {
            margin-right: 6px;
            vertical-align: middle;
            width: 16px;
            height: 16px;
        }

        /* sidebar */
        .sidebar {
            position: relative;
            z-index: 10;
            width: 280px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.6);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            box-shadow: 4px 0 25px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
        }

        .mobile-header {
            display: none;
        }

        .sidebar .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 40px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: center;
            line-height: 1.4;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .sidebar-menu li {
            margin-bottom: 8px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #444;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .sidebar-menu a:hover:not(.active) {
            background: rgba(255, 255, 255, 0.9);
            color: var(--text-dark);
            transform: translateX(4px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        }

        .sidebar-menu a.active {
            background: var(--text-dark);
            color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
            transform: translateX(4px);
        }

        /* dugmici sa bojama loga */
        .logout-btn {
            background: var(--logo-pink);
            color: #222;
            text-align: center;
            font-weight: 700;
            padding: 14px 20px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .logout-btn:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-add {
            padding: 12px 30px;
            background: var(--logo-green);
            color: #222;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            height: 43px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-add:hover {
            background: var(--logo-pink);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .btn-delete {
            padding: 12px 25px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--logo-pink);
            color: #fff;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            transition: 0.3s;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: none;
            cursor: pointer;
            gap: 6px;
        }

        .btn-delete:hover {
            background: var(--logo-green);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(230, 57, 70, 0.3);
        }

        /* paneli i forme */
        .glass-panel {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            margin-bottom: 40px;
            width: 100%;
        }

        .glass-panel h2 {
            margin-top: 0;
            font-weight: 800;
            font-size: 24px;
            color: #111;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
        }

        .form-inline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)) auto;
            gap: 15px;
            align-items: end;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            display: block;
            margin-bottom: 8px;
            color: #555;
            text-transform: uppercase;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            font-family: 'Montserrat', sans-serif;
            background: rgba(255, 255, 255, 0.8);
            box-sizing: border-box;
            font-weight: 600;
            cursor: pointer;
        }

        /* kartice za dogadjaje */
        .event-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            width: 100%;
        }

        .event-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

        .event-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        .event-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, var(--logo-pink), var(--logo-green));
        }

        .e-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 15px 0;
            color: #111;
        }

        .e-detail {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 600;
            color: #444;
            margin-bottom: 12px;
        }

        .e-icon {
            background: #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
            color: #555;
        }

        .e-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: auto;
            padding-top: 20px;
        }

        /* responsive dizajn*/
        @@media screen and (max-width: 768px) {
            .bg-image {
                flex-direction: column;
            }

            .sidebar {
                width: 100% !important;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.4);
                padding: 15px 20px;
            }

            .sidebar .logo-text {
                display: none;
            }

            .mobile-header {
                display: flex;
                justify-content: flex-start;
                align-items: center;
                width: 100%;
                gap: 15px;
            }

            .mobile-header .logo-text-mobile {
                font-size: 20px;
                font-weight: 800;
                color: #111;
                text-transform: uppercase;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .hamburger-btn {
                background: none;
                border: none;
                font-size: 28px;
                cursor: pointer;
                color: #111;
                padding: 0;
                display: flex;
                align-items: center;
            }

            .sidebar-menu {
                display: none;
                flex-direction: column;
                width: 100%;
                margin-top: 20px;
            }

            .sidebar-menu.active {
                display: flex;
            }

            .sidebar-menu a {
                justify-content: center;
            }

            .logout-btn.desktop-only {
                display: none;
            }

            .logout-btn.mobile-only {
                display: flex;
                margin-top: 10px;
            }

            .main-content {
                padding: 30px 15px;
            }

            .glass-panel {
                padding: 25px 20px;
            }

            .form-inline {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .btn-add {
                width: 100%;
                margin-top: 10px;
            }

            .event-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="bg-overlay"></div>

        <div class="sidebar">
            <div class="mobile-header">
                <button class="hamburger-btn" id="hamburgerToggle">
                    <svg class="svg-icon icon-md" id="menuIcon" viewBox="0 0 24 24">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h2 class="logo-text-mobile">
                    <svg class="svg-icon icon-md" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                    </svg>
                    EventDreamer
                </h2>
            </div>
            <div class="logo-text">
                <svg class="svg-icon icon-lg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
                EventDreamer
            </div>

            <ul class="sidebar-menu" id="navContainer">
                <li>
                    <a href="@Url.Action("Index", "Dashboard")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        Kontrolna tabla
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("MojiDogadjaji", "Dashboard")" class="active">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        Moji događaji
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Tasks")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        Lista zadataka
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Guests")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        Lista gostiju
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Budget")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        Budžet i troškovi
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Vendors")">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                        Pronađi vendore
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Logout", "Account")" class="logout-btn mobile-only" style="display: none;">Odjavi se</a>
                </li>
            </ul>
            <a href="@Url.Action("Logout", "Account")" class="logout-btn desktop-only">
                <svg class="svg-icon icon-md" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Odjavi se
            </a>
        </div>

        <div class="main-content">
            <div class="glass-panel">
                <h2>
                    <svg class="svg-icon title-icon" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                    Kreiraj novi događaj
                </h2>
                <form action="@Url.Action("DodajDogadjaj", "Dashboard")" method="post" class="form-inline">
                    <div class="form-group">
                        <label>Naziv događaja</label>
                        <input type="text" name="title" required placeholder="npr. Vjenčanje Ane i Ivana" />
                    </div>
                    <div class="form-group">
                        <label>Datum</label>
                        <input type="date" name="date" required />
                    </div>
                    <div class="form-group">
                        <label>Lokacija (Restoran/Sala)</label>
                        <select name="location" required>
                            <option value=""> Odaberite restoran/salu </option>
                            @if (ViewBag.ListaLokacija != null)
                            {
                                foreach (var selectListItem in (SelectList)ViewBag.ListaLokacija)
                                {
                                    <option value="@selectListItem.Value">@selectListItem.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Ukupan budžet (€)</label>
                        <input type="number" name="totalBudget" step="0.01" required placeholder="0.00" />
                    </div>
                    <button type="submit" class="btn-add">
                        <svg class="svg-icon btn-icon" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        Dodaj
                    </button>
                </form>
            </div>

            <div class="event-grid">
                @if (Model != null && Model.Any())
                {
                    foreach (var e in Model)
                    {
                        <div class="event-card">
                            <h3 class="e-title">@e.Title</h3>

                            <div class="e-detail">
                                <span class="e-icon">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                </span>
                                <span>@(e.Date.HasValue ? e.Date.Value.ToString("dd.MM.yyyy") : "Datum nije određen")</span>
                            </div>

                            <div class="e-detail">
                                <span class="e-icon">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                </span>
                                <span>@(string.IsNullOrEmpty(e.Location) ? "Lokacija na čekanju" : e.Location)</span>
                            </div>

                            <div class="e-detail">
                                <span class="e-icon">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                                </span>
                                <span>Budžet: <strong>@e.TotalBudget €</strong></span>
                            </div>

                            <div class="e-detail" style="margin-top: 5px; color: #1e6091;">
                                <span class="e-icon" style="background: #e2eafc; color: #111;">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                </span>
                                <span>
                                    Ukupno zadataka:
                                    <strong>
                                        @if (ViewBag.BrojZadataka != null && ((Dictionary<int, int>)ViewBag.BrojZadataka).ContainsKey(e.Id))
                                        {
                                            @(((Dictionary<int, int>)ViewBag.BrojZadataka)[e.Id])
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </strong>
                                </span>
                            </div>

                            <div class="e-detail" style="margin-top: 5px; color: #2e7d32;">
                                <span class="e-icon" style="background: var(--logo-green); color: #111;">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                </span>
                                <span>
                                    Potvrđenih gostiju:
                                    <strong>
                                        @if (ViewBag.PotvrdjeniGosti != null && ((Dictionary<int, int>)ViewBag.PotvrdjeniGosti).ContainsKey(e.Id))
                                        {
                                            @(((Dictionary<int, int>)ViewBag.PotvrdjeniGosti)[e.Id])
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </strong>
                                </span>
                            </div>

                            <div class="e-actions">
                                <a href="@Url.Action("ObrisiDogadjaj", "Dashboard", new { id = e.Id })" class="btn-delete" title="Obriši događaj" onclick="return confirm('PAŽNJA! Brisanjem ovog događaja trajno ćete obrisati sve njegove goste, zadatke i cjelokupan budžet. Da li ste sigurni?');">
                                    <svg class="svg-icon icon-sm" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    Obriši događaj
                                </a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; background: rgba(255,255,255,0.6); border-radius: 20px; font-weight: 600; color: #333; border: 1px dashed rgba(0,0,0,0.2);">
                        <svg class="svg-icon icon-md" viewBox="0 0 24 24" style="margin-bottom: 10px; color: #888;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg><br />
                        Još uvijek niste kreirali nijedan događaj. Ispunite formu iznad da počnete!
                    </div>
                }
            </div>

        </div>
    </div>

    <script>
        document.getElementById("hamburgerToggle").addEventListener("click", function () {
            var nav = document.getElementById("navContainer");
            nav.classList.toggle("active");
            var mobileLogout = document.querySelector(".logout-btn.mobile-only");
            var menuIcon = document.getElementById("menuIcon");

            if (nav.classList.contains("active")) {
                menuIcon.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                mobileLogout.style.display = "flex";
            } else {
                menuIcon.innerHTML = '<line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>';
                mobileLogout.style.display = "none";
            }
        });
    </script>
</body>
</html>