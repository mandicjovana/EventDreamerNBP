@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>EventDreamer - Početna</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&family=Syne:wght@500;700;800&display=swap" rel="stylesheet">

    <style>
        /* boje sa loga i fontovi*/

        :root {
            --logo-pink: #F6DEEA;
            --logo-green: #BCC5AA;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6)), url('/Images/pozadina.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            color: #333;
        }

        /* css za pocetnu stranicu */
        .home-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            padding: 20px;
            text-align: center;
        }

        .home-main-logo {
            height: 200px !important;
            width: auto;
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.15));
            transition: transform 0.3s ease;
        }

        .home-main-logo:hover {
            transform: scale(1.05);
        }

        .home-title {
            font-family: 'Syne', sans-serif;
            font-size: 4rem;
            font-weight: 800;
            color: #111;
            letter-spacing: -1px;
            margin: 0;
            text-transform: uppercase;
        }

        .home-subtitle {
            font-size: 1.2rem;
            color: #444;
            max-width: 600px;
            margin-bottom: 40px;
            font-weight: 400;
        }

        /* Dugmici */
        .btn-group {
            display: flex;
            gap: 20px;
        }

        .modern-btn {
            display: inline-block;
            padding: 15px 35px;
            font-size: 1.1rem;
            font-weight: 600;
            border: 2px solid #111;
            border-radius: 50px;
            cursor: pointer;
            background: transparent;
            color: #111;
            text-decoration: none;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            text-align: center;
        }

        .modern-btn:active {
            transform: translateY(-1px);
        }

        .btn-login:hover {
            background: var(--logo-green);
            color: #222;
            border-color: var(--logo-green);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
            transform: translateY(-3px);
        }

        .btn-register {
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
        }

        .btn-register:hover {
            background: var(--logo-pink);
            color: #222;
            border-color: var(--logo-pink);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        /* Responsive design */

        /* Za tablete i vece ekrane */
        @@media (max-width: 768px) {
            .home-title {
                font-size: 6.5vw !important;
                letter-spacing: -2px !important;
                white-space: nowrap !important;
                padding: 0 10px !important;
                line-height: 1.1 !important;
            }

            .home-subtitle {
                font-size: 1rem !important;
                padding: 0 15px !important;
            }

            .btn-group {
                flex-direction: column !important;
                width: 100% !important;
                max-width: 300px !important;
                gap: 15px !important;
                margin: 0 auto !important;
            }

            .modern-btn {
                width: 100% !important;
            }
        }

        /* Za mobilne telefone */
        @@media (max-width: 480px) {
            html, body {
                width: 100% !important;
                max-width: 100vw !important;
                overflow-x: hidden !important;
            }

            .home-container {
                padding: 20px 10px !important;
            }

            .home-main-logo {
                height: 120px !important; 
                padding-top: 0px;
            }
            .home-title {
                font-size: 20px !important; 
                letter-spacing: -0.5px !important;
                white-space: nowrap !important;/*da se slova u rijeci ne prebacuju u drugi red*/
                display: flex !important; /*Da bude centrirano*/
                justify-content: center !important; 
                align-items: center !important; 
                text-align: center !important;
                width: 100% !important;
                max-width: 100vw !important;
                margin: 15px 0 !important;
                padding: 0 !important; 
            }
            .home-subtitle {
                font-size: 0.9rem !important;
                margin-bottom: 30px !important;
                line-height: 1.5 !important;
            }
            .btn-group {
                flex-direction: column !important;
                width: 100% !important;
                max-width: 260px !important;
                gap: 12px !important;
            }
        }
    </style>
</head>
<body>

    <div class="home-container">
        <img src="/Images/logo.png" class="home-main-logo" alt="EventDreamer Logo" onerror="this.style.display='none';" />

        <h1 class="home-title">EventDreamer</h1>

        <p class="home-subtitle">
            "Zaboravite na stres oko organizacije. Pronađite idealan prostor, ritam koji pokreće i dekoraciju koja oduzima dah – sve na jedan klik od vas."
        </p>

        <div class="btn-group">
            <a href="@Url.Action("Login", "Account")" class="modern-btn btn-login">Prijavi se</a>
            <a href="@Url.Action("Register", "Account")" class="modern-btn btn-register">Registruj se</a>
        </div>
    </div>

</body>
</html>